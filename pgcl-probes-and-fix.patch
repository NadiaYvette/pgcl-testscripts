@@ -1270,6 +1270,41 @@ unsigned long tear_down_vmas(struct mm_struct *mm, struct vma_iterator *vmi,
 }
 
 /* Release all mmaps. */
+/*
+ * PGCLDBG (overnight 2026-05-15 #3): exit_mmap mapcount audit probe.
+ * Walk every present PTE in every VMA of the mm right before unmap_vmas
+ * runs.  For each present PTE pointing to a shmem folio, log a line that
+ * lets us correlate against the rmap-helper INC/DEC probes:
+ *   PGCLDBG EXIT_EXPECT pfn=X idx=Y addr=Z pid=N comm=...
+ * Post-process: for each (pid, pfn) tuple, count EXIT_EXPECT events vs
+ * folio_remove_rmap_pte DEC events.  If EXIT_EXPECT fires N times but
+ * DEC only fires N-K times for that pid+pfn, K PTEs were silently lost.
+ */
+static int pgcldbg_exit_audit_pte_entry(pte_t *pte, unsigned long addr,
+		unsigned long next, struct mm_walk *walk)
+{
+	pte_t pteval = ptep_get(pte);
+	struct page *page;
+	struct folio *folio;
+
+	if (!pte_present(pteval))
+		return 0;
+	if (!pfn_valid(pte_pfn(pteval)))
+		return 0;
+	page = pfn_to_page(pte_pfn(pteval));
+	folio = page_folio(page);
+	if (folio_test_swapbacked(folio) && !folio_test_anon(folio))
+		pr_err("PGCLDBG EXIT_EXPECT pfn=%lx idx=%lu addr=%lx pid=%d comm=%.16s mc=%d\n",
+			folio_pfn(folio), folio->index, addr,
+			current->pid, current->comm,
+			folio_mapcount(folio));
+	return 0;
+}
+
+static const struct mm_walk_ops pgcldbg_exit_audit_ops = {
+	.pte_entry = pgcldbg_exit_audit_pte_entry,
+};
+
 void exit_mmap(struct mm_struct *mm)
 {
 	struct mmu_gather tlb;
@@ -1292,6 +1327,14 @@ void exit_mmap(struct mm_struct *mm)
 		goto destroy;
 	}
 
+	/* PGCLDBG: audit every present-shmem PTE about to be torn down */
+	{
+		VMA_ITERATOR(audit_vmi, mm, 0);
+		struct vm_area_struct *avma;
+		for_each_vma(audit_vmi, avma)
+			walk_page_vma(avma, &pgcldbg_exit_audit_ops, NULL);
+	}
+
 	unmap_all_init(&unmap, &vmi, vma);
 	flush_cache_mm(mm);
 	tlb_gather_mmu_fullmm(&tlb, mm);
