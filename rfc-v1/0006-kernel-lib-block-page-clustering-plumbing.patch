diff --git a/kernel/fork.c b/kernel/fork.c
index 8ac38beae360..cfa61579090b 100644
--- a/kernel/fork.c
+++ b/kernel/fork.c
@@ -314,9 +314,9 @@ static int memcg_charge_kernel_stack(struct vm_struct *vm_area)
 	int ret;
 	int nr_charged = 0;
 
-	BUG_ON(vm_area->nr_pages != THREAD_SIZE / PAGE_SIZE);
+	BUG_ON(vm_area->nr_pages != DIV_ROUND_UP(THREAD_SIZE, PAGE_SIZE));
 
