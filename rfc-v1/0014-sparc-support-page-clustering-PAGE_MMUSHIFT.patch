diff --git a/arch/sparc/Kconfig b/arch/sparc/Kconfig
index a6b787efc2c4..f19baea35538 100644
--- a/arch/sparc/Kconfig
+++ b/arch/sparc/Kconfig
@@ -279,6 +279,16 @@ config ARCH_SPARSEMEM_DEFAULT
 
 config ARCH_FORCE_MAX_ORDER
 	int "Order of maximal physically contiguous allocations"
+	# PGCL widens PAGE_SIZE by 2^PAGE_MMUSHIFT; cap MAX_PAGE_ORDER so
+	# PAGE_SHIFT + MAX_PAGE_ORDER stays under SECTION_SIZE_BITS (=30).
+	# `range` clauses force `make olddefconfig` to clamp a stale value
+	# from a smaller-PGCL .config when the user later raises PAGE_MMUSHIFT.
+	range 1 5 if PAGE_MMUSHIFT >= 6
+	range 1 8 if PAGE_MMUSHIFT >= 4
+	range 1 10 if PAGE_MMUSHIFT >= 2
+	default "5" if PAGE_MMUSHIFT >= 6
+	default "8" if PAGE_MMUSHIFT >= 4
+	default "10" if PAGE_MMUSHIFT >= 2
 	default "12"
 	help
 	  The kernel page allocator limits the size of maximal physically
