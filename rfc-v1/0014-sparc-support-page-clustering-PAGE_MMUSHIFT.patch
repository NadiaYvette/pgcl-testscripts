 	ba,pt		%xcc, 699f; \
 	 or		REG1, REG2, REG1; \
 698:	sllx		VADDR, 64 - PMD_SHIFT, REG2; \
-	srlx		REG2, 64 - PAGE_SHIFT, REG2; \
+	srlx		REG2, 64 - MMUPAGE_SHIFT, REG2; \
