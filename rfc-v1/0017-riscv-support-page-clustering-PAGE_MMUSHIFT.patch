 	 * using PMD entries in fixmap_pmd in 64-bit and a PGD entry in 32-bit.
 	 */
 	FIX_FDT_END,
-	FIX_FDT = FIX_FDT_END + FIX_FDT_SIZE / PAGE_SIZE - 1,
+	FIX_FDT = FIX_FDT_END + FIX_FDT_SIZE / MMUPAGE_SIZE - 1,
 
