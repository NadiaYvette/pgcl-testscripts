+			}
+		}
+		count = page_count(page) + swp_swapcount(folio->swap) - 3;
+		if (doing_wp)
+			folio_unlock(folio);
+		else
+			count--;	/* swap not yet freed */
+	} else {
+		count = page_count(page) - 1;
+	}
+	return count ? NULL : page;
+}
