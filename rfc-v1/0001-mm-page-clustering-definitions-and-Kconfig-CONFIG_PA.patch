diff --git a/include/linux/pagemap.h b/include/linux/pagemap.h
index 31a848485ad9..21b0febaf7c5 100644
--- a/include/linux/pagemap.h
+++ b/include/linux/pagemap.h
@@ -1065,15 +1065,36 @@ static inline pgoff_t folio_pgoff(const struct folio *folio)
 	return folio->index;
