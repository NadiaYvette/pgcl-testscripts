 #define __pmd_free_tlb(tlb, x, addr)	tlb_remove_ptdesc((tlb), virt_to_ptdesc(x))
 
 #endif
@@ -80,7 +126,8 @@ static inline pmd_t *pmd_alloc_one(struct mm_struct *mm, unsigned long address)
