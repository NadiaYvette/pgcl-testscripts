diff --git a/arch/mips/Kconfig b/arch/mips/Kconfig
index 4364f3dba688..36b94ba50629 100644
--- a/arch/mips/Kconfig
+++ b/arch/mips/Kconfig
@@ -25,6 +25,10 @@ config MIPS
 	select ARCH_USE_MEMTEST
 	select ARCH_USE_QUEUED_RWLOCKS
 	select ARCH_USE_QUEUED_SPINLOCKS
+	# PGCL packs PAGE_MMUCOUNT MMUPAGE-sized PTE tables into one
+	# PAGE_SIZE ptdesc; ask for one ptlock per sub-table so that
+	# SPLIT_PTE_PTLOCKS keeps working under PGCL.
+	select PACK_PTE_PTLOCKS if PAGE_MMUSHIFT > 0
 	select ARCH_SUPPORTS_HUGETLBFS if CPU_SUPPORTS_HUGEPAGES
 	select ARCH_WANT_DEFAULT_TOPDOWN_MMAP_LAYOUT if MMU
 	select ARCH_WANT_IPC_PARSE_VERSION
@@ -2126,6 +2130,15 @@ config ZBOOT_LOAD_ADDRESS
 
 config ARCH_FORCE_MAX_ORDER
 	int "Maximum zone order"
+	# PGCL widens PAGE_SIZE by 2^PAGE_MMUSHIFT; cap MAX_PAGE_ORDER so
+	# PAGE_SHIFT + MAX_PAGE_ORDER stays under SECTION_SIZE_BITS (=28-29).
+	# `range` clauses force `make olddefconfig` to clamp a stale value.
+	range 1 5 if PAGE_MMUSHIFT >= 6
+	range 1 8 if PAGE_MMUSHIFT >= 4
+	range 1 10 if PAGE_MMUSHIFT >= 2
+	default "5" if PAGE_MMUSHIFT >= 6
+	default "8" if PAGE_MMUSHIFT >= 4
+	default "10" if PAGE_MMUSHIFT >= 2
 	default "13" if MIPS_HUGE_TLB_SUPPORT && PAGE_SIZE_64KB
 	default "12" if MIPS_HUGE_TLB_SUPPORT && PAGE_SIZE_32KB
 	default "11" if MIPS_HUGE_TLB_SUPPORT && PAGE_SIZE_16KB
