diff --git a/mm/debug.c b/mm/debug.c
index 77fa8fe1d641..bea9e8c21551 100644
--- a/mm/debug.c
+++ b/mm/debug.c
@@ -136,6 +136,20 @@ static void __dump_page(const struct page *page)
 		pr_warn("page does not match folio\n");
 
 	__dump_folio(&ps.folio_snapshot, &ps.page_snapshot, ps.pfn, ps.idx);
+#if defined(CONFIG_X86_64)
+	/* #143 post-mortem: when the kernel dumps a bad/victim page, signal QEMU
+	 * (magic cpuid leaf 0x51430004, ebx = 4K-frame base) to walk EVERY pgd and
+	 * print every (cr3,va) still mapping this cluster = the dangling/stale PTE
+	 * that escaped the refcount/mapcount accounting.  Fires at the crash, so it
+	 * does not perturb the race timing. */
+	{
+		unsigned long base = page_to_phys((struct page *)page) >> MMUPAGE_SHIFT;
+		unsigned int a = 0x51430004u, b, c, d;
+
+		asm volatile("cpuid" : "=a"(a), "=b"(b), "=c"(c), "=d"(d)
+				     : "0"(a), "1"(base), "2"(0UL));
+	}
+#endif
 }
 
