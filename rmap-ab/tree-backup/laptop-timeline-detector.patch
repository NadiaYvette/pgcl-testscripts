+#if PAGE_MMUSHIFT
+			/*
+			 * #143 laptop capture (light, non-perturbing): order-0
+			 * mapcount must never drop below -1.  atomic_add_negative()
+			 * can't distinguish -1 (clean last unmap) from -2/-3 (the
+			 * #143 freed-while-mapped / dangling-PTE underflow), so read
+			 * the result and report on underflow.  This fires ONLY on the
+			 * bug, so it does not perturb the timing race (unlike a ring
+			 * tracer); dump_page()+PAGE_OWNER+DEBUG_VM give the page
+			 * history, dump_stack() (once) names the remove path.  No
+			 * WARN/BUG -> cannot trip panic_on_warn/panic on the laptop.
+			 */
+			int v = atomic_sub_return(1, &folio->_mapcount);
+
+			pgcl143_rec(folio_pfn(folio), -1, v,
+				    folio_ref_count(folio), 'r', _RET_IP_);
+			if (unlikely(v < -1)) {
+				static atomic_t pgcl143_uf = ATOMIC_INIT(0);
+				int n = atomic_inc_return(&pgcl143_uf);
