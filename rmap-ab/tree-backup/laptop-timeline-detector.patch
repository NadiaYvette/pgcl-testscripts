+/* === #143 laptop add/remove timeline (per-pfn ring) =====================
+ * Light + NON-perturbing: per-pfn-hashed ring with a NON-atomic, slot-masked
+ * head (zero hot-path atomics).  Records each order-0 mapcount delta with the
+ * resulting mc, the live rc, cpu, a 1-char path tag, and the caller IP.  Dumped
+ * at the underflow catch to expose the under-add / phantom-remove (the captured
+ * signature: mc falling -2..-8 while rc holds steady => mapcount-only removes).
+ */
+#define PGCL143_NB 16384
+#define PGCL143_NK 32
+struct pgcl143_ev { unsigned long pfn, ip; short delta, mc, rc; unsigned char cpu; char tag; };
+static struct { unsigned int head; struct pgcl143_ev ev[PGCL143_NK]; } pgcl143_ring[PGCL143_NB];
+void pgcl143_rec(unsigned long pfn, int delta, int mc, int rc, char tag, unsigned long ip)
+{
+	unsigned int b = pfn & (PGCL143_NB - 1);
+	struct pgcl143_ev *e = &pgcl143_ring[b].ev[pgcl143_ring[b].head++ & (PGCL143_NK - 1)];
+
+	e->pfn = pfn; e->ip = ip; e->delta = delta; e->mc = mc;
+	e->rc = rc > 32767 ? 32767 : rc;
+	e->cpu = raw_smp_processor_id(); e->tag = tag;
+}
+static void pgcl143_dump(unsigned long pfn)
+{
+	unsigned int bb = pfn & (PGCL143_NB - 1), i, h = pgcl143_ring[bb].head;
+
+	pr_err("PGCL143tl: pfn=%lx timeline (last %d on bucket, oldest first)\n",
+	       pfn, PGCL143_NK);
+	for (i = 0; i < PGCL143_NK; i++) {
+		struct pgcl143_ev *e = &pgcl143_ring[bb].ev[(h + i) & (PGCL143_NK - 1)];
+
+		if (e->pfn != pfn || !e->tag)
+			continue;
+		pr_err("   %c d%+d -> mc=%d rc=%d cpu=%u  %pS\n",
+		       e->tag, e->delta, e->mc, e->rc, e->cpu, (void *)e->ip);
+	}
+}
