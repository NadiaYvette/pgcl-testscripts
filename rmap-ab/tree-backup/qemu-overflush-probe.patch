+/*
+ * PGCL #143 over-flush probe: when env PGCL_OVERFLUSH is set, escalate every
+ * guest page/range TLB flush to a FULL flush.  If the bug is the kernel failing
+ * to invalidate a cluster's sibling sub-PTEs (leaving stale softmmu-TLB
+ * entries), this papers over exactly that gap and the repro goes clean ->
+ * confirms a TLB-flush gap.  Toggle without rebuilding via the env var.
+ */
+static bool pgcl_overflush_on(void)
+{
+    static int v = -1;
+    if (v < 0)
+        v = !!getenv("PGCL_OVERFLUSH");
+    return v;
+}
