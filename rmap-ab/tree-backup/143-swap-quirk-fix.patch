 #endif
 }
 
+#if PAGE_MMUSHIFT
+/*
+ * #143 VMA-namer: order-0 mapcount underflow means a sub-PTE was removed that
+ * was never counted (a dangling PTE installed without an rmap event -- invisible
+ * to any rmap-event trace).  We can't see the *creator* here, but the remover
+ * holds the offending @vma, so name the mapping that ACCUMULATED the dangler:
+ * its file (%pD), flags (shared/private/write), pgoff, and the tearing-down
+ * task.  Catch-time only (rare) => zero hot-path cost => responsive.
+ */
+static atomic_t pgcl143_wp_n = ATOMIC_INIT(0);
+static void pgcl143_wp_catch(struct folio *folio, struct page *page,
+			     struct vm_area_struct *vma, int mc)
+{
+	int n = atomic_inc_return(&pgcl143_wp_n);
+
+	if (n > 16)
+		return;
+	pr_err("PGCL143wp #%d: order-0 underflow pfn=%lx mc=%d rc=%d anon=%d mapping=%px\n",
+	       n, folio_pfn(folio), mc, folio_ref_count(folio),
+	       folio_test_anon(folio), folio->mapping);
+	pr_err("   remover comm=%s pid=%d %s-mm vma=%px flags=%#lx pgoff=%lx file=%pD\n",
+	       current->comm, current->pid,
+	       (vma && vma->vm_mm == current->mm) ? "own" : "foreign",
+	       vma, vma ? (unsigned long)vma->vm_flags : 0UL,
+	       vma ? vma->vm_pgoff : 0UL, vma ? vma->vm_file : NULL);
+	dump_page(page, "PGCL143 order-0 underflow");
+	dump_stack();
+}
+
+static bool pgcl143_dangle_one(struct folio *folio, struct vm_area_struct *vma,
+			       unsigned long address, void *arg)
+{
+	DEFINE_FOLIO_VMA_WALK(pvmw, folio, vma, address, PVMW_SYNC);
+	int *cnt = arg;
+
+	while (page_vma_mapped_walk(&pvmw)) {
+		(*cnt)++;
+		pr_err("PGCL143dangle:   comm=%s mm=%px vaddr=%lx (rmap-base=%lx) pte=%lx\n",
+		       current->comm, (void *)vma->vm_mm, pvmw.address, address,
+		       pvmw.pte ? (unsigned long)pte_val(ptep_get(pvmw.pte)) : 0UL);
+	}
+	return true;
+}
+
+/*
+ * #143: called from shrink_folio_list AFTER try_to_unmap left folio_mapped()
+ * == false (mapcount says fully unmapped) and just before the folio is freed.
+ * Re-walk the rmap for any STILL-PRESENT PTE -- a freed-while-mapped, uncounted
+ * dangling mapping (the #143 corruption seed).  Prints each survivor's address
+ * next to the rmap-computed base so an install-vs-walk VA skew shows up.
+ */
+void pgcl143_audit_dangler(struct folio *folio)
+{
+	static atomic_t n = ATOMIC_INIT(0);
+	struct rmap_walk_control rwc = {
+		.rmap_one = pgcl143_dangle_one,
+		.anon_lock = folio_lock_anon_vma_read,
+	};
+	int cnt = 0;
+
+	if (atomic_read(&n) > 24)
+		return;
+	rwc.arg = &cnt;
+	rmap_walk(folio, &rwc);
+	if (cnt && atomic_inc_return(&n) <= 24)
+		pr_err("PGCL143dangle: FREED-WHILE-MAPPED pfn=%lx index=%lx mapcount=%d refcount=%d anon=%d -- %d present PTE(s) survived reclaim\n",
+		       folio_pfn(folio), folio->index, folio_mapcount(folio),
+		       folio_ref_count(folio), folio_test_anon(folio), cnt);
+}
+#endif
