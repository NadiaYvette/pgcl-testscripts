+/*
+ * Minimal 4-level x86_64 walk of an arbitrary cr3, reading guest physical
+ * memory directly.  Returns the mapped 4K frame for a present USER 4K leaf,
+ * else 0.
+ */
+static int pgcl_walk_dbg;
+static uint64_t pgcl_walk(CPUX86State *env, uint64_t cr3, uint64_t va)
+{
+    uint64_t base = cr3 & 0x000ffffffffff000ULL;
+    const int sh[4] = { 39, 30, 21, 12 };
+    int lvl;
+
+    for (lvl = 0; lvl < 4; lvl++) {
+        uint64_t e, pa = base + ((va >> sh[lvl]) & 0x1ff) * 8;
+
+        if (pa >= PGCL_RAMLIMIT) {
+            return 0;                       /* out of backed RAM (MMIO safe) */
+        }
+        /*
+         * Coherent read through the CPU's physical MMU index -- the same
+         * primitive ptw_ldq() falls back to.  address_space_read() returned
+         * stale page-table data from this helper context.
+         */
+        e = cpu_ldq_mmuidx_ra(env, pa, MMU_PHYS_IDX, 0);
+        if (pgcl_walk_dbg) {
+            fprintf(stderr, "  walk lvl%d pa=0x%" PRIx64 " e=0x%" PRIx64 "\n",
+                    lvl, pa, e);
+        }
+        if (!(e & 1)) {
+            return 0;                       /* not present */
+        }
+        if (!(e & 4)) {
+            return 0;                       /* not USER (PG_USER) */
+        }
+        if (lvl < 3 && (e & 0x80)) {
+            return 0;                       /* huge leaf: not our 4K case */
+        }
+        base = e & 0x000ffffffffff000ULL;
+    }
+    return base >> 12;
+}
+
+/*
+ * #143 v3: set of all guest USER pgds (CR3 phys), recorded on every CR3 load
+ * (pgcl_pgd_add from cpu_x86_update_cr3).  Lets us find COLD mappings (a victim
+ * sitting in waitpid is not the last accessor, so access-time recording misses
+ * it) by a full page-table scan, and check ALL fork-sharers of a freed frame.
+ */
+void pgcl_pgd_add(uint64_t cr3);
+void pgcl_pgd_add(uint64_t cr3)
+{
+    uint64_t p = cr3 & 0x000ffffffffff000ULL;
+    int i;
+
+    if (pgcl_dangle_armed != 1 || !p) {
+        return;
+    }
+    for (i = 0; i < pgcl_npgd; i++) {
+        if (pgcl_pgds[i] == p) {
+            return;
+        }
+    }
+    if (pgcl_npgd < PGCL_MAXPGD) {
+        pgcl_pgds[pgcl_npgd++] = p;
+    }
+}
