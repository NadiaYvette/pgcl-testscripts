+/*
+ * PGCL #143 dangling-PTE probe v2 (diagnostic): catch FREE-WHILE-MAPPED at the
+ * instant of the free.  v1 (freed-frame shadow + 4K-leaf walk-check) caught
+ * nothing because QEMU's softmmu TLB caches the dangling translation -- the
+ * kernel never tears the dangling PTE down (that IS the bug) so it is never
+ * flushed/re-walked after the free, and the frame is usually reused before any
+ * re-walk.  v2 keeps a per-frame REVERSE MAP of the last USER (cr3,va) that
+ * walked each frame (recorded at TLB-miss-walk time, so it survives TLB
+ * caching).  When the guest kernel signals a page FREE (magic cpuid leaf
+ * 0x51430001, ebx=4K-frame base, ecx=#frames, via cpu_x86_cpuid), we VALIDATE
+ * by walking that (cr3,va) in guest memory: if a present USER PTE STILL maps the
+ * frame being freed, that is the dangling PTE -- the count-clean free-while-
+ * mapped the in-kernel mapcount/bad_page checks structurally cannot see -- named
+ * (cr3,va,frame) from OUTSIDE the kernel, no latency in the rmap race path.
+ * Alloc (leaf 0x51430000) clears the reverse map.  Armed by env PGCL_DANGLE.
+ */
+struct pgcl_rme { uint64_t cr3; uint64_t va; };
+static struct pgcl_rme *pgcl_rmap;
+static uint64_t pgcl_nframes;
+/*
+ * Page-table reads must stay within backed RAM: a stale/garbage table entry
+ * (churn) or a wrong-level walk can point into the MMIO hole, and a
+ * cpu_ldq_mmuidx_ra() to MMIO from this context core-dumps QEMU.  Bound to the
+ * -m size used by the rmap-ab runs (2G, well below the i440fx PCI hole).  Run
+ * the guest with -cpu max,la57=off so this 4-level walk matches the guest.
+ */
+#define PGCL_RAMLIMIT (2ULL << 30)
+
+/* set of all guest USER pgds (CR3 phys); declared here so the cross-check can use it */
+#define PGCL_MAXPGD 4096
+static uint64_t pgcl_pgds[PGCL_MAXPGD];
+static int pgcl_npgd;
+static unsigned long pgcl_scan_gen;
+
+/*
+ * #143 struct-page reader ("layer inversion"): read the guest kernel's OWN
+ * authoritative _refcount/_mapcount from the vmemmap (struct page array), so we
+ * catch refcount underflow / premature free directly instead of inferring it
+ * from page-table walks.  Layout from pahole on the pgcl4 vmlinux:
+ *   sizeof(struct page)=64, offsetof(_mapcount)=48, offsetof(_refcount)=52.
+ * vmemmap_base = nokaslr 4-level default (run guest -cpu max,la57=off).
+ * vmemmap is indexed by CLUSTER pfn; qsig base is in MMUPAGE frames, so
+ * cluster_pfn = base >> PAGE_MMUSHIFT (PGCL_MMUSHIFT below; 4 for pgcl4, 0 pgcl0).
+ */
+#define PGCL_VMEMMAP_BASE   0xffffea0000000000ULL
+#define PGCL_PAGE_SIZE      64
+#define PGCL_OFF_MAPCOUNT   48
+#define PGCL_OFF_REFCOUNT   52
+#define PGCL_MMUSHIFT       4
+
+/* Walk a KERNEL va (no U-bit) to its guest physical address; handle huge pages. */
+static uint64_t pgcl_kwalk(CPUX86State *env, uint64_t cr3, uint64_t va)
+{
+    uint64_t base = cr3 & 0x000ffffffffff000ULL;
+    static const int sh[4] = { 39, 30, 21, 12 };
+    int lvl;
+
+    for (lvl = 0; lvl < 4; lvl++) {
+        uint64_t e, pa = base + ((va >> sh[lvl]) & 0x1ff) * 8;
+
+        if (pa >= PGCL_RAMLIMIT) {
+            return 0;
+        }
+        e = cpu_ldq_mmuidx_ra(env, pa, MMU_PHYS_IDX, 0);
+        if (!(e & 1)) {
+            return 0;                       /* not present */
+        }
+        if (lvl < 3 && (e & 0x80)) {        /* huge leaf (1G @lvl1 / 2M @lvl2) */
+            uint64_t hmask = (1ULL << sh[lvl]) - 1;
+            return (e & 0x000ffffffffff000ULL & ~hmask) | (va & hmask);
+        }
+        base = e & 0x000ffffffffff000ULL;
+    }
+    return base | (va & 0xfff);             /* 4K leaf */
+}
