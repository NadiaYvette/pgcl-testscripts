+/*
+ * #143 per-write history: every guest atomic RMW funnels through
+ * atomic_mmu_lookup; when the target is a struct page's _refcount(off 52) or
+ * _mapcount(off 48) field in the vmemmap, record (value-before, cpu, guest RIP)
+ * into a per-cluster ring -> the "unwindable history" of every refcount/mapcount
+ * change with the kernel code that made it.  Dumped at free of an interesting
+ * (multi-ref) cluster.  Armed by env PGCL_RCHIST.  cputlb.c is target-agnostic,
+ * so the guest PC comes from cpu->cc->get_pc().  Run guest -cpu max,la57=off.
+ */
+#define PGCL_RC_VMEMMAP   0xffffea0000000000ULL
+#define PGCL_RC_PGSIZE    64
+#define PGCL_RC_MMUSHIFT  4
+#define PGCL_RC_NCLUSTER  (1u << (31 - 16))     /* 2G / 64K */
+#define PGCL_RC_K         24
+/* val = the field being written (value BEFORE the RMW); sib = the SIBLING count
+ * sampled at the same instant (mapcount when val is refcount, and vice versa) so
+ * each event exposes the rc-vs-mc invariant -> "refcount hit 0 while mc>=0" =
+ * page freed while still mapped = the #143 bug, visible directly in the dump. */
+struct pgcl_rcev { uint64_t rip; int32_t val; int32_t sib; uint16_t cpu; uint16_t off; };
+struct pgcl_rcc { uint8_t head; uint8_t maxrc; struct pgcl_rcev e[PGCL_RC_K]; };
+static struct pgcl_rcc *pgcl_rc;
+static int pgcl_rc_armed = -1;
+
+/* #143 DEEP HISTORY: a big global ring of EVERY refcount/mapcount write plus
+ * every free/alloc event, so the symptom (a premature free / corruption) can be
+ * rewound OFFLINE to the causal operation -- no perturbing online walk.  One
+ * qatomic fetch-inc yields a unique seq AND ring slot; the ring overwrites the
+ * oldest.  Sized by PGCL_HISTGB (GiB, off if unset); dumped to PGCL_HISTFILE
+ * (default rmap-ab/pgcl-hist.bin) once at exit (no per-event disk I/O). */
+struct pgcl_hev {
+    uint64_t seq;
+    uint64_t rip;
+    uint32_t frame;     /* cpfn (rc/mc write) or base cpfn (free/alloc) */
+    int32_t  a;         /* writes: refcount-before; free/alloc: 4K-frame count */
+    int32_t  b;         /* writes: mapcount-before; free/alloc: 0 */
+    uint8_t  kind;      /* 0=rc write 1=mc write 2=free 3=alloc 4=nonatomic */
+    uint8_t  cpu;
+    uint8_t  off;       /* 48 (mc) or 52 (rc) */
+    uint8_t  pad;
+};
+static struct pgcl_hev *pgcl_hist;
+static unsigned long pgcl_hist_n;          /* ring capacity (entries) */
+static unsigned long pgcl_hist_head;       /* atomic global counter == seq */
+
+void pgcl_hist_put(uint8_t kind, uint32_t frame, int32_t a, int32_t b,
+                   uint64_t rip, uint8_t cpu, uint8_t off);
+void pgcl_hist_put(uint8_t kind, uint32_t frame, int32_t a, int32_t b,
+                   uint64_t rip, uint8_t cpu, uint8_t off)
+{
+    unsigned long i;
+    struct pgcl_hev *e;
+    if (!pgcl_hist) {
+        return;
+    }
+    i = qatomic_fetch_inc(&pgcl_hist_head);
+    e = &pgcl_hist[i % pgcl_hist_n];
+    e->seq = i; e->rip = rip; e->frame = frame; e->a = a; e->b = b;
+    e->kind = kind; e->cpu = cpu; e->off = off; e->pad = 0;
+}
+
+static void pgcl_hist_dump(void)
+{
+    const char *path = getenv("PGCL_HISTFILE");
+    uint64_t hdr[4];
+    FILE *f;
+    if (!pgcl_hist) {
+        return;
+    }
+    if (!path) {
+        path = "/home/nyc/src/pgcl/rmap-ab/pgcl-hist.bin";
+    }
+    f = fopen(path, "wb");
+    if (!f) {
+        fprintf(stderr, "PGCL143hist: dump open FAIL %s\n", path);
+        return;
+    }
+    /* slots 0..min(head,n)-1 cover all valid entries (not-wrapped: prefix;
+     * wrapped: all n) -- avoids writing GiB of unused zeros for short runs. */
+    unsigned long ndump = pgcl_hist_head < pgcl_hist_n
+                        ? pgcl_hist_head : pgcl_hist_n;
+    hdr[0] = 0x504743484953544cULL;   /* magic "PGCHISTL" */
+    hdr[1] = pgcl_hist_head;          /* total events (>= valid in ring) */
+    hdr[2] = ndump;                   /* entries actually written */
+    hdr[3] = sizeof(struct pgcl_hev);
+    fwrite(hdr, sizeof hdr, 1, f);
+    fwrite(pgcl_hist, sizeof(struct pgcl_hev), ndump, f);
+    fclose(f);
+    fprintf(stderr, "PGCL143hist: dumped %lu/%lu events (ring cap %lu) -> %s\n",
+            ndump, pgcl_hist_head, pgcl_hist_n, path);
+}
+
+static inline void pgcl_rc_record(CPUState *cpu, vaddr addr, void *host,
+                                  uintptr_t retaddr)
+{
+    uint64_t off, cl, rip;
+    struct pgcl_rcc *c;
+    int32_t v, sib;
+
+    if (pgcl_rc_armed < 0) {
+        const char *gb = getenv("PGCL_HISTGB");
+        pgcl_rc_armed = getenv("PGCL_RCHIST") ? 1 : 0;
+        if (pgcl_rc_armed) {
+            pgcl_rc = g_malloc0((size_t)PGCL_RC_NCLUSTER * sizeof(*pgcl_rc));
+            fprintf(stderr, "PGCL143: refcount/mapcount write-history ACTIVE\n");
+        }
+        if (gb) {
+            size_t bytes = (size_t)strtoul(gb, NULL, 10) << 30;
+            pgcl_hist_n = bytes / sizeof(struct pgcl_hev);
+            pgcl_hist = mmap(NULL, pgcl_hist_n * sizeof(struct pgcl_hev),
+                             PROT_READ | PROT_WRITE,
+                             MAP_ANONYMOUS | MAP_PRIVATE | MAP_NORESERVE, -1, 0);
+            if (pgcl_hist == MAP_FAILED) {
+                pgcl_hist = NULL;
+                fprintf(stderr, "PGCL143hist: mmap FAIL\n");
+            } else {
+                pgcl_hist_head = 1;     /* seq 0 == unused slot (mmap-zeroed) */
+                atexit(pgcl_hist_dump);
+                fprintf(stderr, "PGCL143hist: deep-history ring %lu entries"
+                        " (%s GiB) ACTIVE\n", pgcl_hist_n, gb);
+            }
+        }
+    }
+    if (pgcl_rc_armed != 1 || addr < PGCL_RC_VMEMMAP) {
+        return;
+    }
+    off = addr - PGCL_RC_VMEMMAP;
+    cl = off / PGCL_RC_PGSIZE;
+    off %= PGCL_RC_PGSIZE;
+    if (cl >= PGCL_RC_NCLUSTER || (off != 48 && off != 52)) {
+        return;
+    }
+    v = *(volatile int32_t *)host;              /* value BEFORE the RMW */
+    /* sibling count at the same instant: rc field is +4 from mc field */
+    sib = (off == 52) ? *(volatile int32_t *)((char *)host - 4)
+                      : *(volatile int32_t *)((char *)host + 4);
+    /* Exact guest PC of the atomic op.  get_pc() alone is the stale TB-start PC;
+     * cpu_restore_state would unwind it but MODIFIES cpu state mid-op (corrupts
+     * the guest).  cpu_unwind_state_data is read-only, but for CF_PCREL TBs (all
+     * kernel code) x86 saves only the LOW page bits in data[0] (pc & ~PAGE_MASK,
+     * see i386_tr_insn_start / x86_restore_state_to_opc).  QEMU splits TBs at
+     * page boundaries, so the current insn shares get_pc()'s 4K page: rebuild the
+     * full PC = (TB-start page base) | (insn page offset). */
+    {
+        uint64_t ud[4] = { 0 };
+        uint64_t pcbase = cpu->cc->get_pc(cpu);
+        if (cpu_unwind_state_data(cpu, retaddr, ud)) {
+            rip = (pcbase & TARGET_PAGE_MASK) | (ud[0] & ~TARGET_PAGE_MASK);
+        } else {
+            rip = pcbase;
+        }
+    }
+    /* deep-history ring: every rc/mc write, BOTH counts before the op + RIP.
+     * (off52 -> v is refcount, sib is mapcount; off48 -> reversed.) */
+    pgcl_hist_put(off == 52 ? 0 : 1, (uint32_t)cl,
+                  off == 52 ? v : sib, off == 52 ? sib : v, rip,
+                  (uint8_t)cpu->cpu_index, (uint8_t)off);
+    c = &pgcl_rc[cl];
+    c->e[c->head].rip = rip;
+    c->e[c->head].val = v;
+    c->e[c->head].sib = sib;
+    c->e[c->head].cpu = cpu->cpu_index;
+    c->e[c->head].off = off;
+    c->head = (c->head + 1) % PGCL_RC_K;
+    if (off == 52 && v > c->maxrc && v < 255) {
+        c->maxrc = v;                           /* track peak refcount = "interesting" */
+    }
+}
+
+/* dump a cluster's refcount/mapcount write history (called at free) */
+int pgcl_rc_dump(uint64_t cpfn, int only_interesting);
+int pgcl_rc_dump(uint64_t cpfn, int only_interesting)
+{
+    struct pgcl_rcc *c;
+    int k;
+
+    if (pgcl_rc_armed != 1 || cpfn >= PGCL_RC_NCLUSTER) {
+        return 0;
+    }
+    c = &pgcl_rc[cpfn];
+    if (only_interesting && c->maxrc < 2) {
+        return 0;                               /* boring once-mapped page */
+    }
+    fprintf(stderr, "PGCL143rchist cpfn=0x%" PRIx64 " maxrc=%d:", cpfn, c->maxrc);
+    for (k = 0; k < PGCL_RC_K; k++) {
+        int idx = (c->head + k) % PGCL_RC_K;
+        struct pgcl_rcev *e = &c->e[idx];
+        int rc, mc, bad;
+        if (!e->rip) {
+            continue;
+        }
+        /* normalize to (rc, mc) regardless of which field this event wrote */
+        rc = (e->off == 52) ? e->val : e->sib;
+        mc = (e->off == 52) ? e->sib : e->val;
+        /* invariant: a mapped page (mc >= 0 => mc+1 mappings) needs rc >= mc+1.
+         * rc <= mc means fewer refs than mappings = lost/early refcount drop. */
+        bad = (mc >= 0 && rc <= mc);
+        fprintf(stderr, " [%s=%d/%s=%d%s cpu%d @%" PRIx64 "]",
+                e->off == 52 ? "rc" : "mc", e->val,
+                e->off == 52 ? "mc" : "rc", e->sib,
+                bad ? "!" : "", e->cpu, e->rip);
+    }
+    fprintf(stderr, "\n");
+    c->maxrc = 0;                               /* reset for the reused frame */
+    return 1;
+}
