+/* Read the guest kernel's struct page[cpfn] _refcount/_mapcount.  1 on success. */
+static int pgcl_read_page(CPUX86State *env, uint64_t cpfn,
+                          int *refcount, int *mapcount)
+{
+    uint64_t va = PGCL_VMEMMAP_BASE + cpfn * PGCL_PAGE_SIZE;
+    uint64_t pa = pgcl_kwalk(env, env->cr[3], va);
+
+    if (!pa || pa + PGCL_OFF_REFCOUNT + 4 > PGCL_RAMLIMIT) {
+        return 0;
+    }
+    *mapcount = (int)cpu_ldl_mmuidx_ra(env, pa + PGCL_OFF_MAPCOUNT, MMU_PHYS_IDX, 0);
+    *refcount = (int)cpu_ldl_mmuidx_ra(env, pa + PGCL_OFF_REFCOUNT, MMU_PHYS_IDX, 0);
+    return 1;
+}
