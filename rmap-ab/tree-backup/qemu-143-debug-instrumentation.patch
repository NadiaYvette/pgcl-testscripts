+/*
+ * Prune a pgd when its frame is freed: a stale/reused pgd frame (exited process)
+ * walked as a live page table reads garbage -> false FREE-WHILE-MAPPED.  Called
+ * for every freed frame; pgd phys == frame << 12.
+ */
+static void pgcl_pgd_drop(uint64_t pgd_phys)
+{
+    int i;
+    for (i = 0; i < pgcl_npgd; i++) {
+        if (pgcl_pgds[i] == pgd_phys) {
+            pgcl_pgds[i] = pgcl_pgds[--pgcl_npgd];
+            return;
+        }
+    }
+}
+
+/* Recursively record every present USER 4K leaf of one pgd into pgcl_rmap. */
+static void pgcl_scan_level(CPUX86State *env, uint64_t root, uint64_t tbl,
+                            int lvl, uint64_t va)
+{
+    static const int sh[4] = { 39, 30, 21, 12 };
+    int i, hi = (lvl == 0) ? 256 : 512;     /* lvl0: user half only */
+
+    for (i = 0; i < hi; i++) {
+        uint64_t pa = tbl + (uint64_t)i * 8, e, cva;
+
+        if (pa >= PGCL_RAMLIMIT) {
+            continue;
+        }
+        e = cpu_ldq_mmuidx_ra(env, pa, MMU_PHYS_IDX, 0);
+        if (!(e & 1) || !(e & 4)) {
+            continue;                       /* present + USER only */
+        }
+        cva = va | ((uint64_t)i << sh[lvl]);
+        if (lvl == 3) {                     /* 4K leaf */
+            uint64_t f = (e & 0x000ffffffffff000ULL) >> 12;
+            if (f < pgcl_nframes) {
+                pgcl_rmap[f].cr3 = root;
+                pgcl_rmap[f].va = cva;
+            }
+            /* deep-history: a mapping snapshot (kind 5) per present USER leaf.
+             * A (cr3,va)->cpfn mapping that PERSISTS across a FREE of cpfn = the
+             * orphaned/dangling PTE (unmap decremented counts but left the PTE).
+             * a=cr3 frame, b=scan_gen, rip=va, off=sub-index. */
+            {
+                extern void pgcl_hist_put(uint8_t, uint32_t, int32_t, int32_t,
+                                          uint64_t, uint8_t, uint8_t);
+                static int pgcl_mapsnap = -1;   /* off by default (too sparse + huge) */
+                if (pgcl_mapsnap < 0) {
+                    pgcl_mapsnap = getenv("PGCL_MAPSNAP") ? 1 : 0;
+                }
+                if (pgcl_mapsnap) {
+                    pgcl_hist_put(5, (uint32_t)(f >> PGCL_MMUSHIFT),
+                                  (int32_t)(root >> 12), (int32_t)pgcl_scan_gen,
+                                  cva, (uint8_t)env_cpu(env)->cpu_index,
+                                  (uint8_t)(f & ((1u << PGCL_MMUSHIFT) - 1)));
+                }
+            }
+            continue;
+        }
+        if (e & 0x80) {
+            continue;                       /* huge leaf: not our 4K case */
+        }
+        pgcl_scan_level(env, root, e & 0x000ffffffffff000ULL, lvl + 1, cva);
+    }
+}
+
+/* Full scan of all known pgds -> repopulate the reverse map (incl. cold maps). */
+static void pgcl_scan_all(CPUX86State *env)
+{
+    int i;
+    pgcl_scan_gen++;
+    for (i = 0; i < pgcl_npgd; i++) {
+        pgcl_scan_level(env, pgcl_pgds[i], pgcl_pgds[i], 0, 0);
+    }
+}
+
+/* At a free, check EVERY known pgd at the recorded va for a dangling map of f. */
+static int pgcl_check_all_pgds(CPUX86State *env, uint64_t f, uint64_t va)
+{
+    int i, hits = 0;
+    for (i = 0; i < pgcl_npgd; i++) {
+        if (pgcl_walk(env, pgcl_pgds[i], va) == f) {
+            if (pgcl_dangle_hits < 256) {
+                pgcl_dangle_hits++;
+                fprintf(stderr,
+                    "PGCL143dangle #%lu: FREE-WHILE-MAPPED frame=0x%" PRIx64
+                    " still mapped by USER pte cr3=0x%" PRIx64 " va=0x%" PRIx64
+                    " (scan_gen=%lu npgd=%d)\n",
+                    pgcl_dangle_hits, f, pgcl_pgds[i], va,
+                    pgcl_scan_gen, pgcl_npgd);
+                /*
+                 * Dump the freeing context's guest kernel stack = the path that
+                 * is freeing a still-mapped page (the buggy under-removal/free).
+                 */
+                if (pgcl_dangle_hits <= 8) {
+                    uint64_t stk[64];
+                    int j;
+                    if (cpu_memory_rw_debug(env_cpu(env), env->regs[R_ESP],
+                                            (uint8_t *)stk, sizeof stk,
+                                            false) == 0) {
+                        fprintf(stderr, "PGCL143danglepath rsp=0x%llx:\n",
+                                (unsigned long long)env->regs[R_ESP]);
+                        for (j = 0; j < 64; j++) {
+                            if (stk[j] >= 0xffffffff81000000ULL &&
+                                stk[j] <  0xffffffff82a00000ULL) {
+                                fprintf(stderr, "  %016llx\n",
+                                        (unsigned long long)stk[j]);
+                            }
+                        }
+                    }
+                }
+            }
+            hits++;
+        }
+    }
+    return hits;
+}
+
+/*
+ * Fresh, targeted at-free scan: walk one pgd's whole user half RIGHT NOW (no
+ * reliance on the sparse reverse map) for a present USER 4K leaf whose frame
+ * lands in cluster `cl`.  Returns the leaf frame (and its va) on first hit, else
+ * 0.  This is what catches the transient premature-free that periodic sampling
+ * misses: at the instant the cluster returns to buddy, is anyone still mapping it?
+ */
+static uint64_t pgcl_find_in_cluster(CPUX86State *env, uint64_t tbl, int lvl,
+                                     uint64_t va, uint64_t cl, uint64_t *out_va)
+{
+    static const int sh[4] = { 39, 30, 21, 12 };
+    int i, hi = (lvl == 0) ? 256 : 512;
+
+    for (i = 0; i < hi; i++) {
+        uint64_t pa = tbl + (uint64_t)i * 8, e, cva;
+
+        if (pa >= PGCL_RAMLIMIT) {
+            continue;
+        }
+        e = cpu_ldq_mmuidx_ra(env, pa, MMU_PHYS_IDX, 0);
+        if (!(e & 1) || !(e & 4)) {
+            continue;                       /* present + USER only */
+        }
+        cva = va | ((uint64_t)i << sh[lvl]);
+        if (lvl == 3) {
+            uint64_t f = (e & 0x000ffffffffff000ULL) >> 12;
+            if ((f >> PGCL_MMUSHIFT) == cl) {
+                *out_va = cva;
+                return f;
+            }
+            continue;
+        }
+        if (e & 0x80) {
+            continue;                       /* huge leaf: not our 4K case */
+        }
+        {
+            uint64_t r = pgcl_find_in_cluster(env, e & 0x000ffffffffff000ULL,
+                                              lvl + 1, cva, cl, out_va);
+            if (r) {
+                return r;
+            }
+        }
+    }
+    return 0;
+}
+
+/* Count present USER 4K leaves into cluster `cl` within ONE pgd (its sub-PTE
+ * mappings in that address space).  Used to classify a PERSUNDER cluster:
+ *   many pgds x few sub-PTEs each  => Contract-A large anon (mapcount per kernel
+ *                                     page is CORRECT; PERSUNDER = false positive)
+ *   few pgds  x ~PAGE_MMUCOUNT each => per-sub-PTE undercount = the #143 bug. */
+static int pgcl_count_in_cluster(CPUX86State *env, uint64_t tbl, int lvl,
+                                 uint64_t cl)
+{
+    int i, hi = (lvl == 0) ? 256 : 512, n = 0;
+
+    for (i = 0; i < hi; i++) {
+        uint64_t pa = tbl + (uint64_t)i * 8, e;
+
+        if (pa >= PGCL_RAMLIMIT) {
+            continue;
+        }
+        e = cpu_ldq_mmuidx_ra(env, pa, MMU_PHYS_IDX, 0);
+        if (!(e & 1) || !(e & 4)) {
+            continue;
+        }
+        if (lvl == 3) {
+            if (((e & 0x000ffffffffff000ULL) >> 12 >> PGCL_MMUSHIFT) == cl) {
+                n++;
+            }
+            continue;
+        }
+        if (e & 0x80) {
+            continue;
+        }
+        n += pgcl_count_in_cluster(env, e & 0x000ffffffffff000ULL, lvl + 1, cl);
+    }
+    return n;
+}
+
+/* Classify a cluster's mappings across all live pgds: how many distinct address
+ * spaces map it, and the most sub-PTEs any single one uses. */
+static void pgcl_classify_cluster(CPUX86State *env, uint64_t cl,
+                                  int *out_npgd, int *out_maxsub)
+{
+    int i, npgd = 0, maxsub = 0;
+    for (i = 0; i < pgcl_npgd; i++) {
+        int n;
+        if (!pgcl_pgd_live(env, pgcl_pgds[i])) {
+            continue;
+        }
+        n = pgcl_count_in_cluster(env, pgcl_pgds[i], 0, cl);
+        if (n > 0) {
+            npgd++;
+            if (n > maxsub) {
+                maxsub = n;
+            }
+        }
+    }
+    *out_npgd = npgd;
+    *out_maxsub = maxsub;
+}
+
+/* Check every live pgd for a present USER PTE still mapping cluster `cl`.
+ * (Kept for targeted use; NOT called per-free -- the walk perturbs the race.) */
+static G_GNUC_UNUSED int pgcl_cluster_dangle_at_free(CPUX86State *env, uint64_t cl)
+{
+    int i, hits = 0;
+    /* Cheap pre-filter: only clusters that were mapped as of the last periodic
+     * cross-check (<=64 frees ago) can plausibly be freed-while-mapped.  A stale
+     * tally only causes an extra confirming walk (which returns 0), never a false
+     * positive.  This bounds the cost to recently-mapped freed clusters. */
+    if (!pgcl_tally || cl >= PGCL_NCLUSTER || pgcl_tally[cl] == 0) {
+        return 0;
+    }
+    for (i = 0; i < pgcl_npgd; i++) {
+        uint64_t va = 0, f;
+        if (!pgcl_pgd_live(env, pgcl_pgds[i])) {
+            continue;
+        }
+        f = pgcl_find_in_cluster(env, pgcl_pgds[i], 0, 0, cl, &va);
+        if (f && pgcl_dangle_hits < 256) {
+            extern int pgcl_rc_dump(uint64_t cpfn, int only_interesting);
+            pgcl_dangle_hits++;
+            hits++;
+            fprintf(stderr,
+                "PGCL143dangleAF #%lu: FREE-WHILE-MAPPED cl=0x%" PRIx64
+                " frame=0x%" PRIx64 " still mapped USER cr3=0x%" PRIx64
+                " va=0x%" PRIx64 " (npgd=%d)\n",
+                pgcl_dangle_hits, cl, f, pgcl_pgds[i], va, pgcl_npgd);
+            pgcl_rc_dump(cl, 0);    /* the refcount/mapcount history that led here */
+        }
+    }
+    return hits;
+}
+
+/* #143 post-mortem: print EVERY present USER leaf into cluster `cl` in one pgd. */
+static void pgcl_pm_print(CPUX86State *env, uint64_t tbl, int lvl, uint64_t va,
+                          uint64_t cl, uint64_t cr3, int *n)
+{
+    static const int sh[4] = { 39, 30, 21, 12 };
+    int i, hi = (lvl == 0) ? 256 : 512;
+
+    for (i = 0; i < hi; i++) {
+        uint64_t pa = tbl + (uint64_t)i * 8, e, cva;
+
+        if (pa >= PGCL_RAMLIMIT) {
+            continue;
+        }
+        e = cpu_ldq_mmuidx_ra(env, pa, MMU_PHYS_IDX, 0);
+        if (!(e & 1) || !(e & 4)) {
+            continue;
+        }
+        cva = va | ((uint64_t)i << sh[lvl]);
+        if (lvl == 3) {
+            uint64_t f = (e & 0x000ffffffffff000ULL) >> 12;
+            if ((f >> PGCL_MMUSHIFT) == cl) {
+                if (*n < 256) {
+                    fprintf(stderr, "PGCL143PM   cl=0x%" PRIx64 " frame=0x%"
+                            PRIx64 " sub=%u cr3=0x%" PRIx64 " va=0x%" PRIx64
+                            " pte=0x%" PRIx64 "\n", cl, f,
+                            (unsigned)(f & ((1u << PGCL_MMUSHIFT) - 1)),
+                            cr3, cva, e);
+                }
+                (*n)++;
+            }
+            continue;
+        }
+        if (e & 0x80) {
+            continue;
+        }
+        pgcl_pm_print(env, e & 0x000ffffffffff000ULL, lvl + 1, cva, cl, cr3, n);
+    }
+}
+
+/* Post-mortem (called from dump_page via magic cpuid 0x51430004, ebx=4K base):
+ * walk the FAULTING pgd + every tracked live pgd for any present USER PTE still
+ * mapping the just-dumped cluster.  Any hit = the dangling/stale PTE that the
+ * refcount/mapcount accounting never tracked -- the #143 root cause -- shown
+ * with (cr3,va,sub).  One-time at the crash => zero race perturbation. */
+void pgcl_postmortem_walk(CPUX86State *env, uint64_t base);
+void pgcl_postmortem_walk(CPUX86State *env, uint64_t base)
+{
+    uint64_t cl = base >> PGCL_MMUSHIFT;
+    uint64_t cur = env->cr[3] & 0x000ffffffffff000ULL;
+    int i, n = 0;
+
+    if (!pgcl_dangle_on()) {
+        return;
+    }
+    fprintf(stderr, "PGCL143PM-walk base=0x%" PRIx64 " cl=0x%" PRIx64
+            " faulting_cr3=0x%" PRIx64 " npgd=%d\n", base, cl, cur, pgcl_npgd);
+    /* the faulting process first (its context ran dump_page) */
+    if (cur && cur < PGCL_RAMLIMIT) {
+        pgcl_pm_print(env, cur, 0, 0, cl, cur, &n);
+    }
+    /* then every other tracked live pgd (fork-sharers, other processes) */
+    for (i = 0; i < pgcl_npgd; i++) {
+        if (pgcl_pgds[i] == cur || !pgcl_pgd_live(env, pgcl_pgds[i])) {
+            continue;
+        }
+        pgcl_pm_print(env, pgcl_pgds[i], 0, 0, cl, pgcl_pgds[i], &n);
+    }
+    fprintf(stderr, "PGCL143PM-walk cl=0x%" PRIx64 " total_present_USER_PTEs=%d"
+            " (cluster is being dumped/freed: any PTE here is DANGLING)\n",
+            cl, n);
+}
+
+void pgcl_dangle_signal(CPUX86State *env, uint64_t base, uint64_t count,
+                        int freed);
+void pgcl_dangle_signal(CPUX86State *env, uint64_t base, uint64_t count,
+                        int freed)
+{
+    uint64_t i;
+
+    if (!pgcl_dangle_on() || !pgcl_rmap) {
+        return;
+    }
+    /* Refresh the reverse map periodically so cold mappings are covered. */
+    if (freed && (pgcl_n_free % 64) == 0) {
+        pgcl_xcheck_scan(env);         /* PTE-tally vs struct-page accounting cross-check (primary) */
+    }
+    if (freed && (pgcl_n_free % 128) == 0) {
+        pgcl_uf_scan(env);             /* authoritative refcount/mapcount underflow scan */
+    }
+    if (freed && (pgcl_n_free % 512) == 0) {
+        pgcl_scan_all(env);            /* pgd reverse-map for the dangle cross-check */
+    }
+    if (freed) {
+        /*
+         * SELF-TEST of the struct-page reader: at free, the kernel's own
+         * _refcount must read 0 and _mapcount -1 (page returning to buddy).
+         * Garbage here => wrong vmemmap base / layout / MMUSHIFT.
+         */
+        if (pgcl_n_free < 12) {
+            uint64_t cpfn = base >> PGCL_MMUSHIFT;
+            int rc = -77, mc = -77, ok;
+            ok = pgcl_read_page(env, cpfn, &rc, &mc);
+            fprintf(stderr, "PGCL143pgread: free base=0x%" PRIx64 " cpfn=0x%"
+                    PRIx64 " ok=%d refcount=%d mapcount=%d %s\n",
+                    base, cpfn, ok, rc, mc,
+                    (ok && rc == 0 && mc == -1) ? "READER-OK" :
+                    (ok ? "UNEXPECTED" : "READ-FAIL"));
+        }
+        {
+            /* dump the refcount/mapcount write-history of interesting
+             * (multi-ref) clusters being freed = the trajectory + RIPs that led
+             * to this free (the "unwindable history"). */
+            extern int pgcl_rc_dump(uint64_t cpfn, int only_interesting);
+            static unsigned long ndump;
+            uint64_t cf = base >> PGCL_MMUSHIFT;
+            uint64_t cc = base + count;
+            /* NB: the fresh at-free pgd walk (pgcl_cluster_dangle_at_free) is too
+             * perturbing -- it suppressed the race (killinit 0/4).  Detection is
+             * instead done with ZERO per-free cost via the periodic-xcheck
+             * persistent-undercount tracker (PGCL143PERSUNDER). */
+            for (; (cf << PGCL_MMUSHIFT) < cc && ndump < 96; cf++) {
+                if (pgcl_rc_dump(cf, 1)) {
+                    ndump++;
+                }
+            }
+        }
+        pgcl_n_free++;
+    } else {
+        pgcl_n_alloc++;
+    }
+    /* deep-history ring: one free(2)/alloc(3) event per qsig (base cpfn, count) */
+    {
+        extern void pgcl_hist_put(uint8_t, uint32_t, int32_t, int32_t,
+                                  uint64_t, uint8_t, uint8_t);
+        pgcl_hist_put(freed ? 2 : 3, (uint32_t)(base >> PGCL_MMUSHIFT),
+                      (int32_t)count, 0, 0,
+                      (uint8_t)env_cpu(env)->cpu_index, 0);
+    }
+    for (i = 0; i < count; i++) {
+        uint64_t f = base + i;
+        if (f >= pgcl_nframes) {
+            break;
+        }
+        if (freed) {
+            struct pgcl_rme r = pgcl_rmap[f];
+            pgcl_pgd_drop(f << 12);         /* prune if this frame was a pgd */
+            /*
+             * The periodic full scan populates (cr3,va) even for COLD frames
+             * (the victim's long-lived mapping).  Check EVERY known pgd at the
+             * recorded va so all fork-sharers of f are tested -- a present USER
+             * PTE still mapping f while it is being freed is the dangling-PTE
+             * premature-free that the in-kernel mapcount checks cannot see.
+             */
+            if (r.va) {
+                pgcl_check_all_pgds(env, f, r.va);
+            }
+        } else {
+            pgcl_rmap[f].cr3 = 0;           /* (re)alloc: forget old mapper */
+            pgcl_rmap[f].va = 0;
+        }
+    }
+}
+
+static inline void pgcl_rmap_record(CPUX86State *env, uint64_t frame,
+                                    uint64_t cr3, uint64_t va)
+{
+    if (pgcl_rmap && frame < pgcl_nframes) {
+        if (pgcl_n_rec < 4) {
+            uint64_t w;
+            pgcl_walk_dbg = 1;
+            w = pgcl_walk(env, cr3, va);        /* PTE is present right now */
+            pgcl_walk_dbg = 0;
+            fprintf(stderr, "PGCL143rec: frame=0x%" PRIx64 " cr3=0x%" PRIx64
+                    " va=0x%" PRIx64 " selftest=0x%" PRIx64 " %s\n",
+                    frame, cr3 & 0x000ffffffffff000ULL, va, w,
+                    w == frame ? "WALK-OK" : "WALK-BROKEN");
+        }
+        pgcl_n_rec++;
+        pgcl_rmap[frame].cr3 = cr3;
+        pgcl_rmap[frame].va = va;
+    }
+}
