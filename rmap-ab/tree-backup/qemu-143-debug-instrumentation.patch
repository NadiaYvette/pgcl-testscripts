+/*
+ * #143 underflow scanner with unwindable history: periodically read EVERY
+ * cluster's authoritative _refcount/_mapcount and keep a per-cluster ring of
+ * recent snapshots.  Flag the kernel's own invariant violations -- mapcount
+ * below the -1 "unmapped" floor, or a negative refcount = the refcount/mapcount
+ * UNDERFLOW that names #143 -- and dump the trajectory (when it went bad).
+ */
+#define PGCL_CLUSTER_SHIFT (12 + PGCL_MMUSHIFT)            /* 64K cluster @pgcl4 */
+#define PGCL_NCLUSTER      (PGCL_RAMLIMIT >> PGCL_CLUSTER_SHIFT)
+#define PGCL_HK            8
+struct pgcl_ufc { uint8_t head; uint8_t flagged; int rc[PGCL_HK]; int mc[PGCL_HK]; };
+static struct pgcl_ufc *pgcl_uf;
+static unsigned long pgcl_uf_hits;
