+static inline void pgcl_rmap_record(CPUX86State *env, uint64_t frame,
+                                    uint64_t cr3, uint64_t va)
+{
+    if (pgcl_rmap && frame < pgcl_nframes) {
+        if (pgcl_n_rec < 4) {
+            uint64_t w;
+            pgcl_walk_dbg = 1;
+            w = pgcl_walk(env, cr3, va);        /* PTE is present right now */
+            pgcl_walk_dbg = 0;
+            fprintf(stderr, "PGCL143rec: frame=0x%" PRIx64 " cr3=0x%" PRIx64
+                    " va=0x%" PRIx64 " selftest=0x%" PRIx64 " %s\n",
+                    frame, cr3 & 0x000ffffffffff000ULL, va, w,
+                    w == frame ? "WALK-OK" : "WALK-BROKEN");
+        }
+        pgcl_n_rec++;
+        pgcl_rmap[frame].cr3 = cr3;
+        pgcl_rmap[frame].va = va;
+    }
+}
