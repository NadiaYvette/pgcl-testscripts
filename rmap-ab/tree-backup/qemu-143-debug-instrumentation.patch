+static void pgcl_uf_scan(CPUX86State *env)
+{
+    uint64_t c;
+
+    if (!pgcl_uf) {
+        pgcl_uf = g_malloc0(PGCL_NCLUSTER * sizeof(*pgcl_uf));
+    }
+    for (c = 0; c < PGCL_NCLUSTER; c++) {
+        struct pgcl_ufc *u = &pgcl_uf[c];
+        int rc, mc;
+
+        if (!pgcl_read_page(env, c, &rc, &mc)) {
+            continue;
+        }
+        u->rc[u->head] = rc;
+        u->mc[u->head] = mc;
+        u->head = (u->head + 1) % PGCL_HK;
+
+        /*
+         * offset 48 is a union: _mapcount on an in-use page, page_type on a
+         * free/typed page (PGTY_buddy = 0xf0000000 = -268435456).  A genuine
+         * mapcount underflow is a SMALL negative (< -1) on a REFERENCED page
+         * (rc > 0); exclude the page_type sentinel range.  refcount must never
+         * be negative.
+         */
+        if (((rc > 0 && mc < -1 && mc >= -4096) || rc < 0) &&
