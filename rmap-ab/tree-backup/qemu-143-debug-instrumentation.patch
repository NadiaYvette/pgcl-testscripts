+/*
+ * PGCL #143 over-flush probe: when env PGCL_OVERFLUSH is set, escalate every
+ * guest page/range TLB flush to a FULL flush.  If the bug is the kernel failing
+ * to invalidate a cluster's sibling sub-PTEs (leaving stale softmmu-TLB
+ * entries), this papers over exactly that gap and the repro goes clean ->
+ * confirms a TLB-flush gap.  Toggle without rebuilding via the env var.
+ */
+static bool pgcl_overflush_on(void)
+{
+    static int v = -1;
+    if (v < 0) {
+        v = !!getenv("PGCL_OVERFLUSH");
+        if (v)
+            fprintf(stderr, "PGCL143: over-flush ACTIVE\n");
+    }
+    return v;
+}
+
+/*
+ * PGCL #143 TLB-scan catcher: record per-frame the last USER (cpu,vaddr) that
+ * filled a softmmu-TLB entry for it; when the guest kernel signals a page FREE
+ * (magic cpuid), verify that USER TLB entry is still live and still maps the
+ * frame being freed.  A live USER mapping (present-dangler OR stale TLB) to a
+ * frame the kernel is freeing == the #143 use-after-free, caught at the instant
+ * of free with cpu+vaddr.  Records actually-accessed mappings, so it sidesteps
+ * the page-table-walk "churn" problem.  Armed by env PGCL_TLBSCAN.  x86 USER
+ * mmu indices = 2 (USER64) / 3 (USER32).
+ */
+#define PGCL_TS_NFRAMES (2ULL << 20)        /* 8G / 4K */
+static uint64_t *pgcl_ts_own;               /* vaddr_page | cpu<<1 | valid */
+static unsigned long pgcl_ts_hits;
+static unsigned long pgcl_ts_alloc_hits;
+static int pgcl_ts_armed = -1;
+
+static int pgcl_ts_on(void)
+{
+    if (pgcl_ts_armed < 0) {
+        pgcl_ts_armed = getenv("PGCL_TLBSCAN") ? 1 : 0;
+        if (pgcl_ts_armed) {
+            pgcl_ts_own = g_malloc0(PGCL_TS_NFRAMES * sizeof(uint64_t));
+            fprintf(stderr, "PGCL143: TLB-scan catcher ACTIVE\n");
+        }
+    }
+    return pgcl_ts_armed;
+}
+
+static void pgcl_ts_record(CPUState *cpu, vaddr addr, hwaddr phys)
+{
+    uint64_t frame = phys >> TARGET_PAGE_BITS;
+    if (!pgcl_ts_on() || !pgcl_ts_own || frame >= PGCL_TS_NFRAMES) {
+        return;
+    }
+    pgcl_ts_own[frame] = (addr & TARGET_PAGE_MASK) |
+                         ((uint64_t)cpu->cpu_index << 1) | 1;
+}
+
+int pgcl_ts_on_free(uint64_t base, uint64_t count);
+int pgcl_ts_on_free(uint64_t base, uint64_t count)
+{
+    uint64_t f;
+    int caught = 0;
+    if (!pgcl_ts_on() || !pgcl_ts_own) {
+        return 0;
+    }
+    for (f = base; f < base + count && f < PGCL_TS_NFRAMES; f++) {
+        uint64_t own = pgcl_ts_own[f];
+        CPUState *cpu;
+        CPUTLBEntry *te;
+        CPUTLBEntryFull *full;
+        uintptr_t idx;
+        vaddr va;
+        int ci;
+
+        if (!(own & 1)) {
+            continue;
+        }
+        va = own & TARGET_PAGE_MASK;
+        ci = (own >> 1) & 0x7ff;
+        cpu = qemu_get_cpu(ci);
+        if (!cpu || !cpu->neg.tlb.f[2].table) {
+            continue;
+        }
+        idx = (va >> TARGET_PAGE_BITS) &
+              (cpu->neg.tlb.f[2].mask >> CPU_TLB_ENTRY_BITS);
+        te = &cpu->neg.tlb.f[2].table[idx];
+        if ((te->addr_read & TLB_INVALID_MASK) ||
+            (te->addr_read & TARGET_PAGE_MASK) != (va & TARGET_PAGE_MASK)) {
+            continue;                       /* evicted/replaced: not live */
+        }
+        full = &cpu->neg.tlb.d[2].fulltlb[idx];
+        if ((full->phys_addr >> TARGET_PAGE_BITS) != f) {
+            continue;
+        }
+        caught++;
+        if (pgcl_ts_hits < 64) {
+            /* Distinguish present-dangler (PTE still maps f) from stale-TLB
+             * (PTE cleared, TLB not flushed): walk cpu ci's CURRENT page table. */
+            hwaddr pp = cpu_get_phys_page_debug(cpu, va);
+            int ptemap = (pp != (hwaddr)-1) &&
+                         ((pp >> TARGET_PAGE_BITS) == f);
+            pgcl_ts_hits++;
+            fprintf(stderr,
+                "PGCL143tlbscan #%lu: FREE-WHILE-USER-MAPPED frame=0x%" PRIx64
+                " live USER tlb cpu=%d va=0x%" PRIx64 " writable=%d"
+                " pte_maps_frame=%d\n",
+                pgcl_ts_hits, f, ci, (uint64_t)va,
+                !(te->addr_write & TLB_INVALID_MASK), ptemap);
+        }
+    }
+    return caught;
+}
+
+int pgcl_ts_on_alloc(uint64_t base, uint64_t count);
+int pgcl_ts_on_alloc(uint64_t base, uint64_t count)
+{
+    uint64_t f;
+    int caught = 0;
+    if (!pgcl_ts_own) {
+        return 0;
+    }
+    /*
+     * #143 SMOKING GUN: a frame handed to a NEW owner (alloc) while a USER TLB
+     * entry from the PREVIOUS owner is STILL LIVE mapping it.  Unlike the free
+     * catch (benign if a flush lands before reuse), this is the corruption
+     * window itself: the stale entry survived free->realloc with no flush, so
+     * the old VA now reads/writes the new owner's page.  Verify against the
+     * actual current TLB (same liveness test as pgcl_ts_on_free), then clear.
+     */
+    for (f = base; f < base + count && f < PGCL_TS_NFRAMES; f++) {
+        uint64_t own = pgcl_ts_own[f];
+        CPUState *cpu;
+        CPUTLBEntry *te;
+        CPUTLBEntryFull *full;
+        uintptr_t idx;
+        vaddr va;
+        int ci;
+
+        if (!(own & 1)) {
+            continue;
+        }
+        va = own & TARGET_PAGE_MASK;
+        ci = (own >> 1) & 0x7ff;
+        cpu = qemu_get_cpu(ci);
+        if (!cpu || !cpu->neg.tlb.f[2].table) {
+            pgcl_ts_own[f] = 0;
+            continue;
+        }
+        idx = (va >> TARGET_PAGE_BITS) &
+              (cpu->neg.tlb.f[2].mask >> CPU_TLB_ENTRY_BITS);
+        te = &cpu->neg.tlb.f[2].table[idx];
+        if ((te->addr_read & TLB_INVALID_MASK) ||
+            (te->addr_read & TARGET_PAGE_MASK) != (va & TARGET_PAGE_MASK)) {
+            pgcl_ts_own[f] = 0;             /* evicted/replaced: not live */
+            continue;
+        }
+        full = &cpu->neg.tlb.d[2].fulltlb[idx];
+        if ((full->phys_addr >> TARGET_PAGE_BITS) != f) {
+            pgcl_ts_own[f] = 0;
+            continue;
+        }
+        /* Live USER TLB entry into a frame being re-allocated == corruption. */
+        caught++;
+        if (pgcl_ts_alloc_hits < 64) {
+            hwaddr pp = cpu_get_phys_page_debug(cpu, va);
+            int ptemap = (pp != (hwaddr)-1) &&
+                         ((pp >> TARGET_PAGE_BITS) == f);
+            pgcl_ts_alloc_hits++;
+            fprintf(stderr,
+                "PGCL143tlbscan ALLOC #%lu: ALLOC-INTO-STALE-MAPPED frame=0x%"
+                PRIx64 " live USER tlb cpu=%d va=0x%" PRIx64 " writable=%d"
+                " pte_maps_frame=%d\n",
+                pgcl_ts_alloc_hits, f, ci, (uint64_t)va,
+                !(te->addr_write & TLB_INVALID_MASK), ptemap);
+        }
+        pgcl_ts_own[f] = 0;
+    }
+    return caught;
+}
