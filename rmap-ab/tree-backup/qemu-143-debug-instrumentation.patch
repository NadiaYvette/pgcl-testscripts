+    if (!pgcl_under_streak) {
+        pgcl_under_streak = g_malloc0(PGCL_NCLUSTER * sizeof(int));
+    }
+    for (c = 0; c < PGCL_NCLUSTER; c++) {
+        int rc, mc;
+
+        if (pgcl_tally[c] == 0) {
+            pgcl_under_streak[c] = 0;        /* unmapped: reset persistence */
+            continue;                       /* no PTE maps it: nothing to cross-check */
+        }
+        if (!pgcl_read_page(env, c, &rc, &mc)) {
