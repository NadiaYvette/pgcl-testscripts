+/* read struct page[cpfn].flags (offset 0); PG_head=bit6, PG_reserved=bit13 */
+static uint64_t pgcl_page_flags(CPUX86State *env, uint64_t cpfn)
+{
+    uint64_t va = PGCL_VMEMMAP_BASE + cpfn * PGCL_PAGE_SIZE;
+    uint64_t pa = pgcl_kwalk(env, env->cr[3], va);
+
+    if (!pa || pa + 8 > PGCL_RAMLIMIT) {
+        return 0;
+    }
+    return cpu_ldq_mmuidx_ra(env, pa, MMU_PHYS_IDX, 0);
+}
