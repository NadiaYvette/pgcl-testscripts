+/*
+ * PGCL #143 dangling-PTE probe v2 (diagnostic): catch FREE-WHILE-MAPPED at the
+ * instant of the free.  v1 (freed-frame shadow + 4K-leaf walk-check) caught
+ * nothing because QEMU's softmmu TLB caches the dangling translation -- the
+ * kernel never tears the dangling PTE down (that IS the bug) so it is never
+ * flushed/re-walked after the free, and the frame is usually reused before any
+ * re-walk.  v2 keeps a per-frame REVERSE MAP of the last USER (cr3,va) that
+ * walked each frame (recorded at TLB-miss-walk time, so it survives TLB
+ * caching).  When the guest kernel signals a page FREE (magic cpuid leaf
+ * 0x51430001, ebx=4K-frame base, ecx=#frames, via cpu_x86_cpuid), we VALIDATE
+ * by walking that (cr3,va) in guest memory: if a present USER PTE STILL maps the
+ * frame being freed, that is the dangling PTE -- the count-clean free-while-
+ * mapped the in-kernel mapcount/bad_page checks structurally cannot see -- named
+ * (cr3,va,frame) from OUTSIDE the kernel, no latency in the rmap race path.
+ * Alloc (leaf 0x51430000) clears the reverse map.  Armed by env PGCL_DANGLE.
+ */
+struct pgcl_rme { uint64_t cr3; uint64_t va; };
+static struct pgcl_rme *pgcl_rmap;
+static uint64_t pgcl_nframes;
+/*
+ * Page-table reads must stay within backed RAM: a stale/garbage table entry
+ * (churn) or a wrong-level walk can point into the MMIO hole, and a
+ * cpu_ldq_mmuidx_ra() to MMIO from this context core-dumps QEMU.  Bound to the
+ * -m size used by the rmap-ab runs (2G, well below the i440fx PCI hole).  Run
+ * the guest with -cpu max,la57=off so this 4-level walk matches the guest.
+ */
+#define PGCL_RAMLIMIT (2ULL << 30)
+static unsigned long pgcl_dangle_hits;
+static int pgcl_dangle_armed = -1;
+static unsigned long pgcl_n_rec, pgcl_n_free, pgcl_n_alloc;
+
+static int pgcl_dangle_on(void)
+{
+    if (pgcl_dangle_armed < 0) {
+        pgcl_dangle_armed = getenv("PGCL_DANGLE") ? 1 : 0;
+        if (pgcl_dangle_armed) {
+            pgcl_nframes = (uint64_t)8 << (30 - 12);    /* up to 8G RAM */
+            pgcl_rmap = g_malloc0(pgcl_nframes * sizeof(*pgcl_rmap));
+            fprintf(stderr, "PGCL143: dangling-PTE probe v2 ACTIVE\n");
+        }
+    }
+    return pgcl_dangle_armed;
+}
+
+/*
+ * Minimal 4-level x86_64 walk of an arbitrary cr3, reading guest physical
+ * memory directly.  Returns the mapped 4K frame for a present USER 4K leaf,
+ * else 0.
+ */
+static int pgcl_walk_dbg;
+static uint64_t pgcl_walk(CPUX86State *env, uint64_t cr3, uint64_t va)
+{
+    uint64_t base = cr3 & 0x000ffffffffff000ULL;
+    const int sh[4] = { 39, 30, 21, 12 };
+    int lvl;
+
+    for (lvl = 0; lvl < 4; lvl++) {
+        uint64_t e, pa = base + ((va >> sh[lvl]) & 0x1ff) * 8;
+
+        if (pa >= PGCL_RAMLIMIT) {
+            return 0;                       /* out of backed RAM (MMIO safe) */
+        }
+        /*
+         * Coherent read through the CPU's physical MMU index -- the same
+         * primitive ptw_ldq() falls back to.  address_space_read() returned
+         * stale page-table data from this helper context.
+         */
+        e = cpu_ldq_mmuidx_ra(env, pa, MMU_PHYS_IDX, 0);
+        if (pgcl_walk_dbg) {
+            fprintf(stderr, "  walk lvl%d pa=0x%" PRIx64 " e=0x%" PRIx64 "\n",
+                    lvl, pa, e);
+        }
+        if (!(e & 1)) {
+            return 0;                       /* not present */
+        }
+        if (!(e & 4)) {
+            return 0;                       /* not USER (PG_USER) */
+        }
+        if (lvl < 3 && (e & 0x80)) {
+            return 0;                       /* huge leaf: not our 4K case */
+        }
+        base = e & 0x000ffffffffff000ULL;
+    }
+    return base >> 12;
+}
+
+/*
+ * #143 v3: set of all guest USER pgds (CR3 phys), recorded on every CR3 load
+ * (pgcl_pgd_add from cpu_x86_update_cr3).  Lets us find COLD mappings (a victim
+ * sitting in waitpid is not the last accessor, so access-time recording misses
+ * it) by a full page-table scan, and check ALL fork-sharers of a freed frame.
+ */
+#define PGCL_MAXPGD 4096
+static uint64_t pgcl_pgds[PGCL_MAXPGD];
+static int pgcl_npgd;
+static unsigned long pgcl_scan_gen;
+
+void pgcl_pgd_add(uint64_t cr3);
+void pgcl_pgd_add(uint64_t cr3)
+{
+    uint64_t p = cr3 & 0x000ffffffffff000ULL;
+    int i;
+
+    if (pgcl_dangle_armed != 1 || !p) {
+        return;
+    }
+    for (i = 0; i < pgcl_npgd; i++) {
+        if (pgcl_pgds[i] == p) {
+            return;
+        }
+    }
+    if (pgcl_npgd < PGCL_MAXPGD) {
+        pgcl_pgds[pgcl_npgd++] = p;
+    }
+}
+
+/* Recursively record every present USER 4K leaf of one pgd into pgcl_rmap. */
+static void pgcl_scan_level(CPUX86State *env, uint64_t root, uint64_t tbl,
+                            int lvl, uint64_t va)
+{
+    static const int sh[4] = { 39, 30, 21, 12 };
+    int i, hi = (lvl == 0) ? 256 : 512;     /* lvl0: user half only */
+
+    for (i = 0; i < hi; i++) {
+        uint64_t pa = tbl + (uint64_t)i * 8, e, cva;
+
+        if (pa >= PGCL_RAMLIMIT) {
+            continue;
+        }
+        e = cpu_ldq_mmuidx_ra(env, pa, MMU_PHYS_IDX, 0);
+        if (!(e & 1) || !(e & 4)) {
+            continue;                       /* present + USER only */
+        }
+        cva = va | ((uint64_t)i << sh[lvl]);
+        if (lvl == 3) {                     /* 4K leaf */
+            uint64_t f = (e & 0x000ffffffffff000ULL) >> 12;
+            if (f < pgcl_nframes) {
+                pgcl_rmap[f].cr3 = root;
+                pgcl_rmap[f].va = cva;
+            }
+            continue;
+        }
+        if (e & 0x80) {
+            continue;                       /* huge leaf: not our 4K case */
+        }
+        pgcl_scan_level(env, root, e & 0x000ffffffffff000ULL, lvl + 1, cva);
+    }
+}
+
+/* Full scan of all known pgds -> repopulate the reverse map (incl. cold maps). */
+static void pgcl_scan_all(CPUX86State *env)
+{
+    int i;
+    pgcl_scan_gen++;
+    for (i = 0; i < pgcl_npgd; i++) {
+        pgcl_scan_level(env, pgcl_pgds[i], pgcl_pgds[i], 0, 0);
+    }
+}
+
+/* At a free, check EVERY known pgd at the recorded va for a dangling map of f. */
+static int pgcl_check_all_pgds(CPUX86State *env, uint64_t f, uint64_t va)
+{
+    int i, hits = 0;
+    for (i = 0; i < pgcl_npgd; i++) {
+        if (pgcl_walk(env, pgcl_pgds[i], va) == f) {
+            if (pgcl_dangle_hits < 256) {
+                pgcl_dangle_hits++;
+                fprintf(stderr,
+                    "PGCL143dangle #%lu: FREE-WHILE-MAPPED frame=0x%" PRIx64
+                    " still mapped by USER pte cr3=0x%" PRIx64 " va=0x%" PRIx64
+                    " (scan_gen=%lu npgd=%d)\n",
+                    pgcl_dangle_hits, f, pgcl_pgds[i], va,
+                    pgcl_scan_gen, pgcl_npgd);
+                /*
+                 * Dump the freeing context's guest kernel stack = the path that
+                 * is freeing a still-mapped page (the buggy under-removal/free).
+                 */
+                if (pgcl_dangle_hits <= 8) {
+                    uint64_t stk[64];
+                    int j;
+                    if (cpu_memory_rw_debug(env_cpu(env), env->regs[R_ESP],
+                                            (uint8_t *)stk, sizeof stk,
+                                            false) == 0) {
+                        fprintf(stderr, "PGCL143danglepath rsp=0x%llx:\n",
+                                (unsigned long long)env->regs[R_ESP]);
+                        for (j = 0; j < 64; j++) {
+                            if (stk[j] >= 0xffffffff81000000ULL &&
+                                stk[j] <  0xffffffff82a00000ULL) {
+                                fprintf(stderr, "  %016llx\n",
+                                        (unsigned long long)stk[j]);
+                            }
