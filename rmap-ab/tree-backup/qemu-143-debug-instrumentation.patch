+static void pgcl_xcheck_scan(CPUX86State *env)
+{
+    uint64_t c;
+    int i;
+    unsigned long n_inuse = 0, n_match = 0, n_under = 0, n_over = 0, n_freed = 0;
+
+    if (!pgcl_tally) {
+        pgcl_tally = g_malloc0(PGCL_NCLUSTER * sizeof(int));
+    }
+    memset(pgcl_tally, 0, PGCL_NCLUSTER * sizeof(int));
+    for (i = 0; i < pgcl_npgd; i++) {
+        if (pgcl_pgd_live(env, pgcl_pgds[i])) {     /* skip dead/reused pgd frames */
