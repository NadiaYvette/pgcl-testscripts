+/*
+ * #143 THE detector: cross-check the two accounting structures.  Tally the
+ * actual present USER sub-PTEs mapping each cluster (across all live pgds), then
+ * compare to the kernel's own struct page:
+ *   (A) tally>0 but refcount==0  -> a PTE maps a page the kernel has FREED
+ *       (premature free / refcount underflow) -- the #143 corruption directly.
+ *   (B) refcount>0 but _mapcount+1 != tally -> the kernel's mapcount disagrees
+ *       with the real number of sub-PTEs (the under/over-count itself).
+ * Run the guest -cpu max,la57=off (4-level walk).  Churn (dead pgds) is pruned
+ * on free; remaining noise is filtered by the pgcl0 control showing zero.
+ */
+static int *pgcl_tally;
+static int *pgcl_under_streak;       /* #143: consecutive-scan undercount persistence */
+static unsigned long pgcl_pu_reports;
+#define PAGE_MMUCOUNT_HINT (1 << PGCL_MMUSHIFT)   /* sub-PTEs per cluster (pgcl4=16) */
+static void pgcl_classify_cluster(CPUX86State *env, uint64_t cl,
+                                  int *out_npgd, int *out_maxsub);
+static unsigned long pgcl_xck_hits;
+
+/*
+ * x86 PGDs are slab-allocated (pgd_cache), so a freed PGD never fires the qsig
+ * and prune-on-free can't drop it -> pgcl_pgds accumulates dead/reused frames
+ * that, walked as page tables, fabricate garbage PTEs (churn).  A LIVE pgd
+ * shares the kernel-half PML4 entries with every other live pgd; the current
+ * CR3 is always live, so a candidate whose vmemmap-PML4 entry matches the
+ * current CR3's is a real pgd.  A reused frame holding other data will not.
+ */
+static bool pgcl_pgd_live(CPUX86State *env, uint64_t pgd)
+{
+    uint64_t kidx = (PGCL_VMEMMAP_BASE >> 39) & 0x1ff;
+    uint64_t ref = (env->cr[3] & 0x000ffffffffff000ULL) + kidx * 8;
+    uint64_t cand = (pgd & 0x000ffffffffff000ULL) + kidx * 8;
+    uint64_t re, ce;
+
+    if (ref >= PGCL_RAMLIMIT || cand >= PGCL_RAMLIMIT) {
+        return false;
+    }
+    re = cpu_ldq_mmuidx_ra(env, ref, MMU_PHYS_IDX, 0);
+    ce = cpu_ldq_mmuidx_ra(env, cand, MMU_PHYS_IDX, 0);
+    return (re & 1) && re == ce;        /* same present kernel vmemmap PUD */
+}
+
+static void pgcl_tally_level(CPUX86State *env, uint64_t tbl, int lvl)
+{
+    static const int sh[4] = { 39, 30, 21, 12 };
+    int i, hi = (lvl == 0) ? 256 : 512;
+    (void)sh;
+
+    for (i = 0; i < hi; i++) {
+        uint64_t pa = tbl + (uint64_t)i * 8, e;
+
+        if (pa >= PGCL_RAMLIMIT) {
+            continue;
+        }
+        e = cpu_ldq_mmuidx_ra(env, pa, MMU_PHYS_IDX, 0);
+        if (!(e & 1) || !(e & 4)) {
+            continue;                       /* present + USER */
+        }
+        if (lvl == 3) {
+            uint64_t cl = ((e & 0x000ffffffffff000ULL) >> 12) >> PGCL_MMUSHIFT;
+            if (cl < PGCL_NCLUSTER) {
+                pgcl_tally[cl]++;
+            }
+            continue;
+        }
+        if (e & 0x80) {
+            continue;                       /* huge user leaf: skip (not order-0) */
+        }
+        pgcl_tally_level(env, e & 0x000ffffffffff000ULL, lvl + 1);
+    }
+}
