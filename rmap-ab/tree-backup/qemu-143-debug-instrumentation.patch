+    if (!pgcl_dangle_on() || !pgcl_rmap) {
+        return;
+    }
+    /* Refresh the reverse map periodically so cold mappings are covered. */
+    if (freed && (pgcl_n_free % 128) == 0) {
+        pgcl_scan_all(env);
+    }
+    if (freed) {
+        if (pgcl_n_free < 8) {
+            fprintf(stderr, "PGCL143free: base=0x%" PRIx64 " count=0x%" PRIx64
+                    " (recs so far=%lu)\n", base, count, pgcl_n_rec);
+        }
+        pgcl_n_free++;
+    } else {
+        pgcl_n_alloc++;
+    }
+    for (i = 0; i < count; i++) {
+        uint64_t f = base + i;
+        if (f >= pgcl_nframes) {
+            break;
+        }
+        if (freed) {
+            struct pgcl_rme r = pgcl_rmap[f];
+            /*
+             * The periodic full scan populates (cr3,va) even for COLD frames
+             * (the victim's long-lived mapping).  Check EVERY known pgd at the
+             * recorded va so all fork-sharers of f are tested -- a present USER
+             * PTE still mapping f while it is being freed is the dangling-PTE
+             * premature-free that the in-kernel mapcount checks cannot see.
+             */
+            if (r.va) {
+                pgcl_check_all_pgds(env, f, r.va);
+            }
+        } else {
+            pgcl_rmap[f].cr3 = 0;           /* (re)alloc: forget old mapper */
+            pgcl_rmap[f].va = 0;
+        }
+    }
+}
