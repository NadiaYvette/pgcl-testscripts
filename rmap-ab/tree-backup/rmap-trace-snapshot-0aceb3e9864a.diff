+/*
+ * #143 NON-PERTURBING per-CPU race-catcher.  Each CPU appends mapcount-change
+ * events to ITS OWN ring -- no shared atomics, no cross-CPU writes, no gen-hook
+ * -- so it does NOT suppress the tight cross-mm timing the way prior probes did.
+ * On a corruption catch we gather every CPU's events for the victim pfn and
+ * sort by local_clock ts to reconstruct the cross-CPU interleaving.
+ */
+struct pgcl_ev2 {
+	u64 ts;
+	unsigned long pfn;
+	long vaddr;
+	int delta;
+	int mc;		/* resulting order-0 _mapcount */
+	int rc;		/* resulting refcount */
+	u8 tag;
+	u8 cpu;
+};
+/*
+ * Per-pfn buckets: retain each pfn's recent add+remove history regardless of
+ * total rmap volume (a flat ring rolls the adds out under the hog's millions of
+ * faults).  add/rem split so removes can't evict adds.  NO gen-hook (the past
+ * suppressor) -- the per-event rc spots free/reuse boundaries (rc hits 0 at a
+ * free; a later add at the same pfn = a reused incarnation).  Per-bucket atomic
+ * head is the only shared write (ring3/4 had this and still caught).
+ */
+#define PGCL_NB2 8192
+#define PGCL_K2  16
+struct pgcl_bucket2 {
+	atomic_t ahead, rhead;
+	struct pgcl_ev2 add[PGCL_K2];
+	struct pgcl_ev2 rem[PGCL_K2];
+};
+static struct pgcl_bucket2 pgcl_buckets2[PGCL_NB2];
+
+/* Remove callers stash their vaddr here (the rmap helpers don't get it), so
+ * REMOVE events record WHERE the torn-down PTE was -> identifies a dangling
+ * PTE (one whose vaddr belongs to an old incarnation of a reused pfn). */
+static DEFINE_PER_CPU(unsigned long, pgcl_rm_va);
+void pgcl_ev2_rm_va(unsigned long va) { this_cpu_write(pgcl_rm_va, va); }
+
+void pgcl_ev2_log(const struct folio *folio, int delta, long vaddr, int tag)
+{
+	unsigned long pfn = folio_pfn(folio);
+	struct pgcl_bucket2 *b = &pgcl_buckets2[pfn & (PGCL_NB2 - 1)];
+	struct pgcl_ev2 *e;
+
+	preempt_disable();	/* local_clock()/smp_processor_id() need it */
+	if (delta >= 0)
+		e = &b->add[(unsigned int)(atomic_inc_return(&b->ahead) - 1)
+			    % PGCL_K2];
+	else
+		e = &b->rem[(unsigned int)(atomic_inc_return(&b->rhead) - 1)
+			    % PGCL_K2];
+	e->ts = local_clock();
+	e->pfn = pfn;
+	/* removes pass -1; substitute the caller's stashed vaddr */
+	e->vaddr = (delta < 0 && vaddr == -1) ? (long)this_cpu_read(pgcl_rm_va)
+					      : vaddr;
+	e->delta = delta;
+	e->mc = atomic_read(&folio->_mapcount);
+	e->rc = folio_ref_count(folio);
+	e->tag = (u8)tag;
+	e->cpu = raw_smp_processor_id();
+	preempt_enable();
+}
+
+void pgcl_ev2_dump(unsigned long pfn)
+{
+	struct pgcl_bucket2 *b = &pgcl_buckets2[pfn & (PGCL_NB2 - 1)];
+	struct pgcl_ev2 buf[2 * PGCL_K2];
+	int n = 0, i, j;
+
+	for (i = 0; i < PGCL_K2; i++) {
+		if (b->add[i].ts && b->add[i].pfn == pfn)
+			buf[n++] = b->add[i];
+		if (b->rem[i].ts && b->rem[i].pfn == pfn)
+			buf[n++] = b->rem[i];
+	}
+	/* selection sort by ts ascending */
+	for (i = 0; i < n; i++)
+		for (j = i + 1; j < n; j++)
+			if (buf[j].ts < buf[i].ts) {
+				struct pgcl_ev2 t = buf[i];
+
+				buf[i] = buf[j];
+				buf[j] = t;
+			}
+	pr_alert("PGCL#143tl: timeline pfn=%lx (%d events, oldest first; rc=0 => free/reuse boundary)\n",
+		 pfn, n);
+	for (i = 0; i < n; i++)
+		pr_alert("  ts=%llu cpu=%u %c d%+d -> mc=%d rc=%d va=%lx\n",
+			 buf[i].ts, buf[i].cpu,
+			 buf[i].tag ? buf[i].tag : '?', buf[i].delta,
+			 buf[i].mc, buf[i].rc, (unsigned long)buf[i].vaddr);
+}
