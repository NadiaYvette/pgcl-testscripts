+/*
+ * #143 diagnostic (UNCOMMITTED debug): attribute an order-0 mapcount UNDERFLOW
+ * to a concurrent cross-mm operation on the SAME cluster.  Each candidate path
+ * publishes the folio pfn it is currently mutating into a per-CPU slot (cheap,
+ * no shared atomics -> minimal perturbation).  When a remove drives _mapcount
+ * below -1, we scan the OTHER CPUs' slots; a match means another CPU was
+ * mid-operation on the very folio that just underflowed (tag says which path).
+ */
+struct pgcl_wp_pub { unsigned long pfn; u8 tag; };
+static DEFINE_PER_CPU(struct pgcl_wp_pub, pgcl_wp_pub);
+
+void pgcl_wp_publish(unsigned long pfn, int tag)
+{
+	struct pgcl_wp_pub *p = this_cpu_ptr(&pgcl_wp_pub);
+
+	WRITE_ONCE(p->tag, (u8)tag);
+	WRITE_ONCE(p->pfn, pfn);
+}
+
+static atomic_t pgcl_wp_reports = ATOMIC_INIT(0);
+
+void pgcl143_wp_check(const struct folio *folio, const char *site)
+{
+	unsigned long pfn = folio_pfn(folio);
+	int cpu, self = raw_smp_processor_id(), hit = -1;
+	u8 htag = 0;
+
+	if (atomic_inc_return(&pgcl_wp_reports) > 16)
+		return;
+	for_each_online_cpu(cpu) {
+		struct pgcl_wp_pub *p;
+
+		if (cpu == self)
+			continue;
+		p = &per_cpu(pgcl_wp_pub, cpu);
+		if (READ_ONCE(p->pfn) == pfn) {
+			hit = cpu;
+			htag = READ_ONCE(p->tag);
+			break;
+		}
+	}
+	if (hit >= 0)
+		pr_alert("PGCL#143wp: order-0 UNDERFLOW pfn=%lx _mapcount=%d refcount=%d anon=%d site=%s cpu=%d CONCURRENT tag=%c@cpu=%d\n",
+			 pfn, atomic_read(&folio->_mapcount),
+			 folio_ref_count(folio), folio_test_anon(folio),
+			 site, self, htag ? htag : '?', hit);
+	else
+		pr_alert("PGCL#143wp: order-0 UNDERFLOW pfn=%lx _mapcount=%d refcount=%d anon=%d site=%s cpu=%d (no concurrent publisher)\n",
+			 pfn, atomic_read(&folio->_mapcount),
+			 folio_ref_count(folio), folio_test_anon(folio),
+			 site, self);
+	dump_stack();
+	pgcl_ev2_dump(pfn);
+}
+
+/*
+ * #143 premature-free CULPRIT probe: a folio reaching refcount 0 while still
+ * mapped (folio_mapped() true) is being freed by whoever dropped its last ref
+ * with a mapping still outstanding -- the backtrace here NAMES that culprit
+ * (migrate_folio_move / shrink_folio_list / zap / truncate ...).
+ */
+static atomic_t pgcl_fm_reports = ATOMIC_INIT(0);
+
+void pgcl143_freed_mapped(const struct folio *folio, const char *site)
+{
+	if (atomic_inc_return(&pgcl_fm_reports) > 16)
+		return;
+	if (folio_test_large(folio))
+		pr_alert("PGCL#143fm: FREED-WHILE-MAPPED pfn=%lx order=%u anon=%d LARGE _large_mapcount=%d _nr_pages_mapped=%d _entire=%d refcount=%d mapping=%px site=%s cpu=%d\n",
+			 folio_pfn(folio), folio_order(folio),
+			 folio_test_anon(folio),
+			 atomic_read(&folio->_large_mapcount),
+			 atomic_read(&folio->_nr_pages_mapped),
+			 atomic_read(&folio->_entire_mapcount),
+			 folio_ref_count(folio), (void *)folio->mapping,
+			 site, raw_smp_processor_id());
+	else
+		pr_alert("PGCL#143fm: FREED-WHILE-MAPPED pfn=%lx order=0 anon=%d _mapcount=%d refcount=%d mapping=%px site=%s cpu=%d\n",
+			 folio_pfn(folio), folio_test_anon(folio),
+			 atomic_read(&folio->_mapcount),
+			 folio_ref_count(folio), (void *)folio->mapping,
+			 site, raw_smp_processor_id());
+	dump_stack();
+	pgcl_ev2_dump(folio_pfn(folio));
+}
