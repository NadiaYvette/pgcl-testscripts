diff --git a/mm/rmap.c b/mm/rmap.c
index 7f797beeca91..4831dbe9980f 100644
--- a/mm/rmap.c
+++ b/mm/rmap.c
@@ -1432,7 +1432,26 @@ static __always_inline void __folio_add_rmap(struct folio *folio,
 	switch (level) {
 	case PGTABLE_LEVEL_PTE:
 		if (!folio_test_large(folio)) {
+#if PAGE_MMUSHIFT
+			/*
+			 * #143 fix candidate: an order-0 folio under PGCL is a
+			 * PAGE_MMUCOUNT-sub-page cluster, so a caller can add
+			 * nr_pages > 1 sub-PTE mappings at once.  Mainline's
+			 * atomic_inc ignores nr_pages (one page == one PTE there),
+			 * UNDER-COUNTING the cluster's _mapcount and seeding a
+			 * freed-while-mapped deficit.  Add nr_pages and detect the
+			 * unmapped(-1)->mapped transition; nr_pages == 1 is
+			 * byte-identical to the mainline atomic_inc_and_test path.
+			 */
+			int old = atomic_fetch_add(nr_pages, &folio->_mapcount);
+
+			WARN_ONCE(nr_pages > 1,
+				  "PGCL143-ord0-add nr_pages=%d pfn=%lx\n",
+				  nr_pages, folio_pfn(folio));
+			nr = (old < 0 && old + nr_pages >= 0) ? nr_pages : 0;
+#else
 			nr = atomic_inc_and_test(&folio->_mapcount);
+#endif
 			break;
 		}
 
@@ -1915,7 +1934,24 @@ static __always_inline void __folio_remove_rmap(struct folio *folio,
 	switch (level) {
 	case PGTABLE_LEVEL_PTE:
 		if (!folio_test_large(folio)) {
+#if PAGE_MMUSHIFT
+			/*
+			 * #143 fix candidate (symmetric to the add side): subtract
+			 * nr_pages sub-PTE mappings from the order-0 cluster's
+			 * _mapcount, not a blind 1.  An under-remove here would
+			 * strand mappings (count too high); the matching add fix
+			 * keeps install/teardown balanced.  nr_pages == 1 is
+			 * byte-identical to the mainline atomic_add_negative path.
+			 */
+			int old = atomic_fetch_sub(nr_pages, &folio->_mapcount);
+
+			WARN_ONCE(nr_pages > 1,
+				  "PGCL143-ord0-rm nr_pages=%d pfn=%lx\n",
+				  nr_pages, folio_pfn(folio));
+			nr = (old >= 0 && old - nr_pages < 0) ? nr_pages : 0;
+#else
 			nr = atomic_add_negative(-1, &folio->_mapcount);
+#endif
 			break;
 		}
 
