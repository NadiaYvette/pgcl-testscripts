+/* === #143 folio-guard A/B (core_param pgcl143_guard) ====================
+ * 0 = off, 1 = folio-pfn-hashed spinlock (serializes the file rmap count+PTE
+ * step ACROSS mms on the same folio), 2 = per-CPU placebo (same lock/unlock
+ * cost, never serializes cross-mm).  Taken under the PTL (PTL -> glock order,
+ * consistent on install and teardown), so no lock inversion.  DEBUG ONLY.
+ */
+int pgcl143_guard;
+core_param(pgcl143_guard, pgcl143_guard, int, 0644);
+#define PGCL_GLOCKS 4096
+static spinlock_t pgcl_glocks[PGCL_GLOCKS];
+static DEFINE_PER_CPU(spinlock_t, pgcl_placebo_lock);
+static int __init pgcl143_guard_init(void)
+{
+	int i;
+	unsigned int c;
+
+	for (i = 0; i < PGCL_GLOCKS; i++)
+		spin_lock_init(&pgcl_glocks[i]);
+	for_each_possible_cpu(c)
+		spin_lock_init(per_cpu_ptr(&pgcl_placebo_lock, c));
+	return 0;
+}
+core_initcall(pgcl143_guard_init);
+static inline spinlock_t *pgcl143_glock(unsigned long pfn)
+{
+	if (pgcl143_guard == 1)
+		return &pgcl_glocks[pfn & (PGCL_GLOCKS - 1)];
+	if (pgcl143_guard == 2)
+		return this_cpu_ptr(&pgcl_placebo_lock);
+	return NULL;
+}
