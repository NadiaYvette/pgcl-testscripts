 	flush_icache_pages(vma, page, nr);
 	entry = mk_pte(page, vma->vm_page_prot);
@@ -6497,6 +6538,11 @@ void set_pte_range(struct vm_fault *vmf, struct folio *folio,
 		 * per-page counter with no scan, because the zap removes the
 		 * same way.
