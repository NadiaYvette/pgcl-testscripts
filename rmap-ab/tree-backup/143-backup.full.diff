+/*
+ * PGCL #143 diagnostic (DEBUG).  Two cooperating parts:
+ *  (1) a per-CPU, lockless count-history ring (pgcl_ring_record) recording every
+ *      rmap count event WITH the folio identity + post-counters, so on an anomaly
+ *      we replay which CPUs/paths touched the buggy folio (and can spot a count
+ *      landing on the wrong folio).  Per-CPU + local_clock => no shared cacheline,
+ *      so it perturbs the cross-CPU race far less than a global counter would.
+ *  (2) pgcl143_report(): on an order-0 OR large mapcount / _nr_pages_mapped
+ *      anomaly, or a folio_mapped()-at-truncate fatal (called from
+ *      filemap_unaccount_folio), dump the folio, the ring slice for its pfn
+ *      across all CPUs, the live mapper sub-PTE map, an all-CPU NMI snapshot, and
+ *      a stack trace.  Strip before any non-debug build.
+ */
+#define PGCL_NBUCKET	8192		/* power of 2: pfn-hash buckets */
+#define PGCL_KADD	32		/* adds retained per pfn-bucket */
+#define PGCL_KREM	32		/* removes retained per pfn-bucket */
+
+struct pgcl_ev {
+	u64 ts;
+	const void *folio;
+	unsigned long pfn;
+	long vaddr;
+	int delta;
+	int mc;			/* _mapcount (small) or _large_mapcount (large), after */
+	int npm;		/* _nr_pages_mapped after (large), else INT_MIN */
+	short poff;		/* page - &folio->page */
+	u8 path;
+	u8 large;
+	u8 cpu;
+	u32 gen;		/* bucket generation at record time (pfn-reuse filter) */
+};
+/*
+ * Per-pfn bucket, with adds and removes in SEPARATE rings (Nadia's idea): a
+ * flood of removes cannot evict the adds, so the under-add / over-remove balance
+ * for a pfn stays legible across the whole repro.  Sequence the two by ts in
+ * post-processing.  Per-bucket atomic heads => contention only when two CPUs
+ * touch the SAME pfn (exactly the racing folio we want), ~NBUCKET x less than a
+ * global counter, so it perturbs the race far less.
+ */
+struct pgcl_bucket {
+	struct pgcl_ev add[PGCL_KADD];
+	struct pgcl_ev rem[PGCL_KREM];
+	atomic_t add_head;
+	atomic_t rem_head;
+	atomic_t gen;		/* bumped on folio free; SUM filters to current gen */
+};
+static struct pgcl_bucket pgcl_buckets[PGCL_NBUCKET];	/* ~33MB BSS, DEBUG only */
+static const char pgcl_ev_ch[] = " arARnce";	/* indexed by enum pgcl_ev_path */
+/*
+ * Per-CPU stash: remove callers set the vaddr here (the rmap helpers don't get
+ * it), so REMOVE events can record their address too — to tell a concurrent
+ * double-remove of ONE sub-PTE (same vaddr, multiple CPUs) from legitimate
+ * removes of several distinct mappings.
+ */
+static DEFINE_PER_CPU(unsigned long, pgcl_rm_va);
+void pgcl_ring_rm_va(unsigned long va) { this_cpu_write(pgcl_rm_va, va); }
+
+/* Called under the page-table lock (preemption off) at every rmap count site. */
+void pgcl_ring_record(const struct folio *folio, const struct page *page,
+		      int delta, long vaddr, unsigned int path)
+{
+	unsigned long pfn = folio_pfn(folio);
+	struct pgcl_bucket *b = &pgcl_buckets[pfn & (PGCL_NBUCKET - 1)];
+	bool large = folio_test_large(folio);
+	struct pgcl_ev *e;
+
+	if (delta >= 0)
+		e = &b->add[(unsigned int)(atomic_inc_return(&b->add_head) - 1)
+			    % PGCL_KADD];
+	else
+		e = &b->rem[(unsigned int)(atomic_inc_return(&b->rem_head) - 1)
+			    % PGCL_KREM];
+
+	e->ts = local_clock();
+	e->folio = folio;
+	e->pfn = pfn;
+	/* Removes don't carry a vaddr through the rmap helpers; use the caller's
+	 * per-CPU stash so we can see if concurrent removes hit the same sub-PTE. */
+	e->vaddr = (delta < 0) ? (long)this_cpu_read(pgcl_rm_va) : vaddr;
+	e->delta = delta;
+	e->large = large;
+	e->mc = large ? atomic_read(&folio->_large_mapcount)
+		      : atomic_read(&folio->_mapcount);
+	e->npm = large ? atomic_read(&folio->_nr_pages_mapped) : INT_MIN;
+	e->poff = (short)(page - &folio->page);
+	e->path = path;
+	e->cpu = raw_smp_processor_id();
+	e->gen = (u32)atomic_read(&b->gen);
+}
+
+/*
+ * Called from the page-free path: bump this pfn's bucket generation so the dump
+ * (and SUM) ignore the just-freed incarnation's events — defeats pfn-reuse
+ * pollution and makes a post-free stale remove show as remove-without-add.
+ */
+void pgcl_ring_free(unsigned long pfn)
+{
+	atomic_inc(&pgcl_buckets[pfn & (PGCL_NBUCKET - 1)].gen);
+}
+
+static void pgcl143_dump_evs(const char *tag, struct pgcl_ev *arr, unsigned int k,
+			     unsigned long pfn, u32 gen, long *sum, long *sum_old)
+{
+	unsigned int i;
+
+	for (i = 0; i < k; i++) {
+		struct pgcl_ev *e = &arr[i];
+		char p = (e->path < sizeof(pgcl_ev_ch)) ? pgcl_ev_ch[e->path] : '?';
+
+		if (e->pfn != pfn || !e->folio)
+			continue;
+		if (e->gen != gen) {		/* a prior incarnation at this pfn */
+			*sum_old += e->delta;
+			continue;
+		}
+		*sum += e->delta;
+		pr_emerg("PGCL#143:   %s %llu c%u %c d%+d mc=%d npm=%d poff=%d va=%lx f=%px%s\n",
+			 tag, e->ts, e->cpu, p, e->delta, e->mc, e->npm, e->poff,
+			 e->vaddr, e->folio, e->large ? " L" : "");
+	}
+}
+
+/* Dump this pfn's bucket (adds then removes; sort by ts in post-processing). */
+void pgcl143_dump_ring(unsigned long pfn)
+{
+	struct pgcl_bucket *b = &pgcl_buckets[pfn & (PGCL_NBUCKET - 1)];
+	u32 gen = (u32)atomic_read(&b->gen);
+	long add_sum = 0, rem_sum = 0, add_old = 0, rem_old = 0;
+
+	pr_emerg("PGCL#143: count-history pfn %lx gen=%u [tag ts cpu path d<delta> mc npm poff va folio] (a=add_rmap r=rem_rmap A=add_sub R=rem_sub n=new_anon c=cow_extra e=anon_eager; L=large; only THIS gen shown):\n",
+		 pfn, gen);
+	pgcl143_dump_evs("ADD", b->add, PGCL_KADD, pfn, gen, &add_sum, &add_old);
+	pgcl143_dump_evs("REM", b->rem, PGCL_KREM, pfn, gen, &rem_sum, &rem_old);
+	pr_emerg("PGCL#143:   SUM(gen %u) adds=%+ld removes=%+ld net=%+ld (net should == current mapcount) | prior-gen filtered: adds=%+ld removes=%+ld\n",
+		 gen, add_sum, rem_sum, add_sum + rem_sum, add_old, rem_old);
+}
+
+static bool pgcl143_rmap_one(struct folio *folio, struct vm_area_struct *vma,
+			     unsigned long address, void *arg)
+{
+	unsigned long cbase = address & PAGE_MASK;
+	unsigned long fpfn = folio_pfn(folio);
+	struct mm_struct *mm = vma->vm_mm;
+	char map[PAGE_MMUCOUNT + 1];
+	char soff[PAGE_MMUCOUNT + 1];
+	unsigned int i, idx, n = 0;
+	unsigned int vsub = (address & (PAGE_SIZE - 1)) >> MMUPAGE_SHIFT;
+	int *count = arg;
+	pgd_t *pgd;
+	p4d_t *p4d;
+	pud_t *pud;
+	pmd_t *pmd;
+	pte_t *pte;
+	unsigned long pmdv = 0;
+	char pbuf[PAGE_MMUCOUNT * 20];	/* raw pte_val of every window slot */
+	unsigned int pl = 0;
+
+	pbuf[0] = '\0';
+	for (i = 0; i < PAGE_MMUCOUNT; i++)
+		map[i] = soff[i] = '?';
+	map[PAGE_MMUCOUNT] = soff[PAGE_MMUCOUNT] = '\0';
+
+	pgd = pgd_offset(mm, cbase);
+	if (pgd_none(*pgd) || pgd_bad(*pgd))
+		goto out;
+	p4d = p4d_offset(pgd, cbase);
+	if (p4d_none(*p4d) || p4d_bad(*p4d))
+		goto out;
+	pud = pud_offset(p4d, cbase);
+	if (pud_none(*pud) || pud_bad(*pud))
+		goto out;
+	pmd = pmd_offset(pud, cbase);
+	pmdv = pmd_val(*pmd);
+	if (pmd_none(*pmd) || pmd_bad(*pmd) || pmd_trans_huge(*pmd))
+		goto out;
+	pte = pte_offset_map(pmd, cbase);
+	if (!pte)
+		goto out;
+	idx = pte_index(cbase);
+	n = min_t(unsigned int, PAGE_MMUCOUNT, PTRS_PER_PTE - idx);
+	for (i = 0; i < n; i++) {
+		pte_t e = ptep_get(pte + i);
+
+		pl += scnprintf(pbuf + pl, sizeof(pbuf) - pl, "%lx ",
+				(unsigned long)pte_val(e));
+		if (pte_none(e)) {
+			map[i] = '.'; soff[i] = '.';		/* empty slot */
+		} else if (!pte_present(e)) {
+			map[i] = 's'; soff[i] = 's';		/* swap / migration */
+		} else if (pte_pfn(e) == fpfn) {
+			unsigned int so = pte_suboffset(e);
+
+			map[i] = pte_write(e) ? 'W' : 'r';	/* live, this folio */
+			soff[i] = "0123456789abcdef"[so & 0xf];	/* its sub-offset */
+		} else {
+			map[i] = 'X'; soff[i] = 'X';		/* present, OTHER pfn */
+		}
+	}
+	pte_unmap(pte);
+out:
+	pr_emerg("PGCL#143:  mapper mm=%px vma=[%lx-%lx] pgoff=%lx flags=%lx anon_vma=%px addr=%lx vsub=%u file=%pD\n",
+		 mm, vma->vm_start, vma->vm_end, vma->vm_pgoff, vma->vm_flags,
+		 vma->anon_vma, address, vsub, vma->vm_file);
+	pr_emerg("PGCL#143:    pmd=%lx kind[%s] suboff[%s] (kind W=wr r=ro .=none s=swap X=otherpfn; suboff=hex sub-page this PTE targets)\n",
+		 pmdv, map, soff);
+	pr_emerg("PGCL#143:    raw pte_val[%u of %u slots]: %s\n",
+		 n, (unsigned int)PAGE_MMUCOUNT, pbuf);
+	if (count && ++*count >= 64)
+		return false;			/* cap volume */
+	return true;
+}
