+void pgcl143_report(struct folio *folio, struct page *page,
+		    struct vm_area_struct *vma, const char *site)
+{
+	static atomic_t dumps = ATOMIC_INIT(0);
+	int seq = atomic_inc_return(&dumps);
+	struct rmap_walk_control rwc = {};
+	int count = 0;
+
+	if (seq > 5)
+		return;				/* bound volume: first 5 anomalies */
+
+	pr_emerg("PGCL#143: ===== anomaly #%d at %s =====\n", seq, site);
+	if (folio_test_large(folio))
+		pr_emerg("PGCL#143: folio=%px pfn=%lx order=%u LARGE _large_mapcount=%d _nr_pages_mapped=%d folio_mapcount=%d refcount=%d anon=%d swapcache=%d\n",
+			 folio, folio_pfn(folio), folio_order(folio),
+			 atomic_read(&folio->_large_mapcount),
+			 atomic_read(&folio->_nr_pages_mapped),
+			 folio_mapcount(folio), folio_ref_count(folio),
