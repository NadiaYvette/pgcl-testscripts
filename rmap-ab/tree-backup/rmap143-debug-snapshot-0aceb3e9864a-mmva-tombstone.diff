+/*
+ * #143 CREATOR-SIDE race-catcher.  At reclaim's free-decision (try_to_unmap has
+ * declared the folio fully unmapped: folio_mapped()==false, about to
+ * __remove_mapping/free), re-walk the folio's rmap.  Any PTE that SURVIVES is a
+ * dangling sub-PTE about to be orphaned by the free -> the #143 bug, caught at
+ * creation (not at the much-later zap that the kernel's Bad-page-map reports).
+ * The re-walk observes the SETTLED state after the try_to_unmap-vs-faulter race,
+ * so it catches a race-induced i_mmap miss without perturbing the race window.
+ * It also names any CPU concurrently publishing operations on the victim pfn.
+ */
+struct pgcl143_vchk { int found; unsigned long pfn; const char *site; };
+
+static bool pgcl143_check_one(struct folio *folio, struct vm_area_struct *vma,
+			      unsigned long address, void *arg)
+{
+	struct pgcl143_vchk *v = arg;
+	DEFINE_FOLIO_VMA_WALK(pvmw, folio, vma, address, 0);
+
+	while (page_vma_mapped_walk(&pvmw)) {
+		int cpu, self, hit = -1;
+		u8 htag = 0;
+
+		if (!pvmw.pte || !pte_present(ptep_get(pvmw.pte)))
+			continue;
+		v->found++;
+		self = raw_smp_processor_id();
+		for_each_online_cpu(cpu) {
+			struct pgcl_wp_pub *p;
+
+			if (cpu == self)
+				continue;
+			p = &per_cpu(pgcl_wp_pub, cpu);
+			if (READ_ONCE(p->pfn) == v->pfn) {
+				hit = cpu;
+				htag = READ_ONCE(p->tag);
+				break;
+			}
+		}
+		pr_alert("PGCL#143cr: SURVIVING PTE at %s pfn=%lx mm=%px addr=%lx anon=%d nr_sub=%u %s tag=%c@cpu=%d\n",
+			 v->site, v->pfn, (void *)vma->vm_mm, pvmw.address,
+			 folio_test_anon(folio), pvmw.nr_mmupages,
+			 hit >= 0 ? "CONCURRENT" : "(no concurrent publisher)",
+			 (hit >= 0 && htag) ? htag : '?', hit);
+	}
+	return true;
+}
+
+void pgcl143_verify_unmapped(struct folio *folio, const char *site)
+{
+	struct pgcl143_vchk v = { .found = 0, .pfn = folio_pfn(folio), .site = site };
+	struct rmap_walk_control rwc = {
+		.arg = &v,
+		.rmap_one = pgcl143_check_one,
+	};
+
+	/* folio is locked here; rmap_walk takes the i_mmap/anon read lock itself */
+	rmap_walk(folio, &rwc);
+	if (v.found) {
+		pr_alert("PGCL#143cr: %d surviving PTE(s) after %s declared pfn=%lx unmapped (mc=%d rc=%d)\n",
+			 v.found, site, v.pfn, atomic_read(&folio->_mapcount),
+			 folio_ref_count(folio));
+		dump_stack();
+		pgcl_ev2_dump(v.pfn);
+	} else if (folio_mapped(folio)) {
+		/*
+		 * rmap_walk found NO PTE, yet folio_mapped() (mapcount) says the
+		 * folio IS mapped.  The mapping is therefore i_mmap/anon-tree
+		 * UNREACHABLE -- every tree-driven unmap (try_to_unmap,
+		 * unmap_mapping_folio) AND this walk miss it, so the folio is freed
+		 * while still counted-mapped (filemap.c:155 BUG / later dangling PTE).
+		 * This mapcount-vs-rmap divergence is the #143 root; dump the folio's
+		 * index/mapping so we can see WHY the tree query can't reach it.
+		 */
+		static atomic_t disc = ATOMIC_INIT(0);
+
+		if (atomic_inc_return(&disc) <= 24) {
+			pr_alert("PGCL#143disc: mapcount-mapped but rmap-walk found 0 PTEs at %s pfn=%lx index=%lx mapping=%px mc=%d lmc=%d rc=%d anon=%d large=%d\n",
+				 site, v.pfn, folio->index, (void *)folio->mapping,
+				 atomic_read(&folio->_mapcount),
+				 atomic_read(&folio->_large_mapcount),
+				 folio_ref_count(folio), folio_test_anon(folio),
+				 folio_test_large(folio));
+			dump_stack();
+			pgcl_ev2_dump(v.pfn);
+			pgcl_lev_dump(v.pfn);
+		}
+	}
+}
+
+/*
+ * #143 NON-PERTURBING per-CPU race-catcher.  Each CPU appends mapcount-change
+ * events to ITS OWN ring -- no shared atomics, no cross-CPU writes, no gen-hook
+ * -- so it does NOT suppress the tight cross-mm timing the way prior probes did.
+ * On a corruption catch we gather every CPU's events for the victim pfn and
+ * sort by local_clock ts to reconstruct the cross-CPU interleaving.
+ */
+struct pgcl_ev2 {
+	u64 ts;
+	unsigned long pfn;
+	long vaddr;
+	unsigned long mm;	/* owning mm (disambiguates fork-shared vaddrs) */
+	int delta;
+	int mc;		/* order-0 _mapcount, or _large_mapcount for large folios */
+	int nm;		/* _nr_pages_mapped for large folios (-1 for order-0) */
+	int rc;		/* resulting refcount */
+	u8 tag;
+	u8 cpu;
+};
+/*
+ * Per-pfn buckets: retain each pfn's recent add+remove history regardless of
+ * total rmap volume (a flat ring rolls the adds out under the hog's millions of
+ * faults).  add/rem split so removes can't evict adds.  NO gen-hook (the past
+ * suppressor) -- the per-event rc spots free/reuse boundaries (rc hits 0 at a
+ * free; a later add at the same pfn = a reused incarnation).  Per-bucket atomic
+ * head is the only shared write (ring3/4 had this and still caught).
+ */
+#define PGCL_NB2 8192
+#define PGCL_K2  16
+struct pgcl_bucket2 {
+	atomic_t ahead, rhead;
+	struct pgcl_ev2 add[PGCL_K2];
+	struct pgcl_ev2 rem[PGCL_K2];
+};
+static struct pgcl_bucket2 pgcl_buckets2[PGCL_NB2];
+
+/*
+ * vaddr-keyed install-add tracking (#143 "very sure" probe).  The pfn-bucket
+ * loses a dangling PTE's *creating* add once the pfn is freed+reused under the
+ * hog (the reused incarnation's adds roll it out).  These buckets are keyed by
+ * the CLUSTER virtual address (vaddr >> PAGE_SHIFT, so all PAGE_MMUCOUNT
+ * sub-PTEs of one cluster collide) and retain only vaddr-bearing ADDs
+ * (n/e/c/f/F -- the high-level install paths).  A dangling REMOVE at vaddr V
+ * then looks up V's cluster here: the retained add whose pfn == the victim pfn
+ * is the install that created the dangling PTE, and its TAG names the path --
+ * surviving pfn reuse because the key is the vaddr, not the pfn.
+ */
+#define PGCL_NVA 8192
+#define PGCL_VK  16		/* >= PAGE_MMUCOUNT so a full cluster's installs are all retained */
+struct pgcl_va_bucket {
+	atomic_t ahead, rhead;
+	struct pgcl_ev2 add[PGCL_VK];
+	struct pgcl_ev2 rem[PGCL_VK];
+};
+static struct pgcl_va_bucket pgcl_va_buckets[PGCL_NVA];
+
+/* pgcl_rm_va is defined ahead of pgcl143_wp_check (above); here is its setter.
+ * pgcl_rm_caller tags the teardown PATH ('z' zap/munmap/truncate, 'w'
+ * rmap-walk = try_to_unmap/try_to_migrate) so the (mm,va) tracker can name
+ * which remove was the count-only one. */
+static DEFINE_PER_CPU(int, pgcl_rm_caller);
+void pgcl_ev2_rm_va(unsigned long va, int caller)
+{
+	this_cpu_write(pgcl_rm_va, va);
+	this_cpu_write(pgcl_rm_caller, caller);
+}
+
+/*
+ * #143 (mm, sub-PTE-VA)-EXACT tracker.  The cluster-keyed va-bucket conflates
+ * the 16 sub-offsets and its small ring evicts an install across the folio's
+ * lifetime, so it cannot name the install of a HIGH-offset dangling FILE PTE.
+ * This is a per-(mm,va) hash with add-set / rem-CLEAR: a slot is occupied only
+ * while (mm,va) is mapped, so a *dangling* (mm,va) -- installed, never removed
+ * before its folio was freed -- KEEPS its install record until the late
+ * teardown.  FILE folios only (the proven victim class), which keeps the table
+ * tiny so load stays low and the dangling slot is never evicted by a colliding
+ * live mapping.  At the dangling teardown (a rem whose folio refcount is
+ * already 0 == freed-while-mapped) we print the retained install -> NAMES the
+ * leaking install path; a rem with NO tracked install -> over-remove / unlogged
+ * install path.
+ */
+/*
+ * NO-CLEAR (tombstone) variant: an install activates the slot; the FIRST
+ * remove turns it into a tombstone (retaining the first-remove's path/rc/ts)
+ * instead of clearing; a SECOND remove of the same (mm,va) == DOUBLE-REMOVE
+ * (the count-only-then-dangling-zap pair) and is dumped, naming the FIRST
+ * remove's path (the count-only culprit).  A later install at a tombstone
+ * reactivates it; a new (mm,va) needing a slot prefers empty, then a
+ * tombstone, then evicts way 0.  nrem: 0 = active, >=1 = tombstone/removed.
+ */
+struct pgcl_sv {
+	unsigned long mm, va, add_pfn, r1_pfn;
+	u64 add_ts, r1_ts;
+	int r1_rc, nrem;
+	u8 add_tag, add_cpu, r1_tag, r1_cpu;
+};
+#define PGCL_NSV (1u << 18)
+#define PGCL_SVW 2
+static struct pgcl_sv pgcl_svtab[PGCL_NSV][PGCL_SVW];
+static atomic_t pgcl_sv_reports = ATOMIC_INIT(0);
+
+static inline u32 pgcl_sv_hash(unsigned long mm, unsigned long va)
+{
+	u64 x = (mm >> 6) * 0x9e3779b97f4a7c15ULL + (va >> MMUPAGE_SHIFT);
+
+	x ^= x >> 29;
+	return (u32)x & (PGCL_NSV - 1);
+}
+
+static void pgcl_sv_record(unsigned long mm, unsigned long vaddr, int delta,
+			   unsigned long pfn, int rc, int tag, u64 ts, u8 cpu)
+{
+	unsigned long base = vaddr & ~((unsigned long)MMUPAGE_SIZE - 1);
+	int cnt = delta < 0 ? -delta : delta;
+	int rtag = tag;
+	int i, w;
+
+	if (delta < 0) {		/* removes: prefer the caller PATH tag */
+		rtag = this_cpu_read(pgcl_rm_caller);
+		if (!rtag)
+			rtag = tag;
+	}
+	if (cnt < 1)
+		cnt = 1;
+	if (cnt > PAGE_MMUCOUNT)
+		cnt = PAGE_MMUCOUNT;
+	for (i = 0; i < cnt; i++) {
+		unsigned long va = base + (unsigned long)i * MMUPAGE_SIZE;
+		struct pgcl_sv *b = pgcl_svtab[pgcl_sv_hash(mm, va)];
+		struct pgcl_sv *slot = NULL;
+
+		for (w = 0; w < PGCL_SVW; w++)
+			if (b[w].mm == mm && b[w].va == va) {
+				slot = &b[w];
+				break;
+			}
+
+		if (delta > 0) {		/* INSTALL (re)activates the slot */
+			if (!slot)
+				for (w = 0; w < PGCL_SVW; w++)
+					if (!b[w].mm) { slot = &b[w]; break; }
+			if (!slot)
+				for (w = 0; w < PGCL_SVW; w++)
+					if (b[w].nrem) { slot = &b[w]; break; }
+			if (!slot)
+				slot = &b[0];
+			slot->mm = mm;
+			slot->va = va;
+			slot->add_pfn = pfn;
+			slot->add_ts = ts;
+			slot->add_tag = (u8)tag;
+			slot->add_cpu = cpu;
+			slot->nrem = 0;
+			slot->r1_pfn = 0;
+			slot->r1_ts = 0;
+			slot->r1_rc = 0;
+			slot->r1_tag = 0;
+			slot->r1_cpu = 0;
+		} else if (slot) {		/* TEARDOWN */
+			if (slot->nrem == 0) {	/* first remove -> tombstone (kept) */
+				slot->r1_pfn = pfn;
+				slot->r1_ts = ts;
+				slot->r1_rc = rc;
+				slot->r1_tag = (u8)rtag;
+				slot->r1_cpu = cpu;
+				slot->nrem = 1;
+			} else {		/* SECOND remove == DOUBLE-REMOVE = the bug */
+				if (slot->nrem < 1000000)
+					slot->nrem++;
+				if (atomic_inc_return(&pgcl_sv_reports) <= 24)
+					pr_alert("PGCL#143sv: DOUBLE-REMOVE va=%lx mm=%lx | install '%c' pfn=%lx ts=%llu cpu=%u | 1st-rem '%c' pfn=%lx rc=%d cpu=%u ts=%llu | 2nd-rem '%c' pfn=%lx rc=%d cpu=%u => 1st-rem dropped the mapcount but left the PTE present; folio freed; 2nd-rem (zap) underflowed.  CULPRIT = the '%c' (1st-rem) path ('z'=zap/munmap/truncate, 'w'=rmap-walk reclaim/migrate).\n",
+						 va, mm,
+						 slot->add_tag ? slot->add_tag : '?',
+						 slot->add_pfn, slot->add_ts, slot->add_cpu,
+						 slot->r1_tag ? slot->r1_tag : '?',
+						 slot->r1_pfn, slot->r1_rc, slot->r1_cpu, slot->r1_ts,
+						 rtag ? rtag : '?', pfn, rc, cpu,
+						 slot->r1_tag ? slot->r1_tag : '?');
+			}
+		}
+		/* delta<0 with no slot: install evicted/untracked -- skip */
+	}
+}
+
+void pgcl_ev2_log(const struct folio *folio, int delta, long vaddr, int tag,
+		  unsigned long mm)
+{
+	unsigned long pfn = folio_pfn(folio);
+	struct pgcl_bucket2 *b = &pgcl_buckets2[pfn & (PGCL_NB2 - 1)];
+	struct pgcl_ev2 *e;
+
+	preempt_disable();	/* local_clock()/smp_processor_id() need it */
+	/* removes stash their mm too, so the catch can mm-match the va-dump */
+	if (delta < 0)
+		this_cpu_write(pgcl_rm_mm, mm);
+	if (delta >= 0)
+		e = &b->add[(unsigned int)(atomic_inc_return(&b->ahead) - 1)
+			    % PGCL_K2];
+	else
+		e = &b->rem[(unsigned int)(atomic_inc_return(&b->rhead) - 1)
+			    % PGCL_K2];
+	e->ts = local_clock();
+	e->pfn = pfn;
+	/* removes pass -1; substitute the caller's stashed vaddr */
+	e->vaddr = (delta < 0 && vaddr == -1) ? (long)this_cpu_read(pgcl_rm_va)
+					      : vaddr;
+	e->mm = mm;
+	e->delta = delta;
+	if (folio_test_large(folio)) {
+		e->mc = atomic_read(&folio->_large_mapcount);
+		e->nm = atomic_read(&folio->_nr_pages_mapped);
+	} else {
+		e->mc = atomic_read(&folio->_mapcount);
+		e->nm = -1;
+	}
+	e->rc = folio_ref_count(folio);
+	e->tag = (u8)tag;
+	e->cpu = raw_smp_processor_id();
+	/*
+	 * Mirror vaddr-bearing INSTALLS (n/e/c/f/F/S) AND REMOVES into the
+	 * cluster-keyed bucket so BOTH sides survive this pfn's later
+	 * free+reuse -- letting the catch sum net = Sigma delta over the
+	 * victim pfn+mm and classify under-remove (net>0 = a dangling PTE,
+	 * an install with no matching teardown) vs over-remove (net<0).
+	 * e->vaddr already holds the effective vaddr (removes substituted the
+	 * stashed rm_va above); e->vaddr<=0 means no vaddr (file a/A adds, or
+	 * a remove with no stashed rm_va) -- skip those.
+	 */
+	if (e->vaddr > 0) {
+		unsigned long cl = (unsigned long)e->vaddr >> PAGE_SHIFT;
+		struct pgcl_va_bucket *vb =
+			&pgcl_va_buckets[cl & (PGCL_NVA - 1)];
+
+		if (delta >= 0)
+			vb->add[(unsigned int)(atomic_inc_return(&vb->ahead) - 1)
+				% PGCL_VK] = *e;
+		else
+			vb->rem[(unsigned int)(atomic_inc_return(&vb->rhead) - 1)
+				% PGCL_VK] = *e;
+	}
+	/*
+	 * (mm,va)-EXACT tracker (FILE folios only -- the proven #143 victim
+	 * class).  Names the install path of a dangling FILE PTE at its late
+	 * teardown (a rem whose folio is already freed, rc==0).
+	 */
+	if (!folio_test_anon(folio) && e->vaddr > 0)
+		pgcl_sv_record(mm, (unsigned long)e->vaddr, delta, pfn,
+			       e->rc, tag, e->ts, e->cpu);
+	preempt_enable();
+}
+
+void pgcl_ev2_dump(unsigned long pfn)
+{
+	struct pgcl_bucket2 *b = &pgcl_buckets2[pfn & (PGCL_NB2 - 1)];
+	struct pgcl_ev2 buf[2 * PGCL_K2];
+	int n = 0, i, j;
+
+	for (i = 0; i < PGCL_K2; i++) {
+		if (b->add[i].ts && b->add[i].pfn == pfn)
+			buf[n++] = b->add[i];
+		if (b->rem[i].ts && b->rem[i].pfn == pfn)
+			buf[n++] = b->rem[i];
+	}
+	/* selection sort by ts ascending */
+	for (i = 0; i < n; i++)
+		for (j = i + 1; j < n; j++)
+			if (buf[j].ts < buf[i].ts) {
+				struct pgcl_ev2 t = buf[i];
+
+				buf[i] = buf[j];
+				buf[j] = t;
+			}
+	pr_alert("PGCL#143tl: timeline pfn=%lx (%d events, oldest first; rc=0 => free/reuse boundary)\n",
+		 pfn, n);
+	for (i = 0; i < n; i++)
+		pr_alert("  ts=%llu cpu=%u %c d%+d -> mc=%d nm=%d rc=%d va=%lx\n",
+			 buf[i].ts, buf[i].cpu,
+			 buf[i].tag ? buf[i].tag : '?', buf[i].delta,
+			 buf[i].mc, buf[i].nm, buf[i].rc, (unsigned long)buf[i].vaddr);
+}
+
+/*
+ * Dump the install-ADDs retained for the cluster of a dangling remove's vaddr.
+ * The entry whose pfn == the victim pfn is the install that created the dangling
+ * PTE; its tag names the path -- and unlike the pfn timeline this survives the
+ * victim pfn's free+reuse (keyed by vaddr-cluster, not pfn).
+ */
+/*
+ * Dump the install-ADDs and teardown-REMOVEs retained for the cluster of a
+ * dangling remove's vaddr, and classify.  net = Sigma delta over the events
+ * that touch the victim pfn in the same mm (and same cluster, surviving the
+ * pfn's free+reuse because the key is the vaddr-cluster, not the pfn):
+ *   net > 0  UNDER-REMOVE: an install has no matching teardown -> a dangling
+ *            PTE; the >>> ADD tag(s) name the leaking install path.
+ *   net < 0  OVER-REMOVE: a teardown has no matching install.
+ *   net == 0 the imbalance predates the retained window or is elsewhere.
+ * Caveat: if the SAME cluster vaddr was mapped/unmapped repeatedly for the
+ * victim pfn in this mm, net sums across incarnations -- read the per-event
+ * ts order (rc=0 marks a free/reuse boundary) to isolate the live one.
+ */
+void pgcl_va_dump(unsigned long rmva, unsigned long rmmm, unsigned long pfn)
+{
+	unsigned long cl = rmva >> PAGE_SHIFT;
+	struct pgcl_va_bucket *vb = &pgcl_va_buckets[cl & (PGCL_NVA - 1)];
+	int i, found = 0, nadd = 0, nrem = 0;
+	long net = 0;
+
+	pr_alert("PGCL#143va: events for dangling cluster va=%lx (clbase=%lx) victim pfn=%lx mm=%lx\n"
+		 "  (>>> = victim pfn + same-mm; net>0 => UNDER-REMOVE/dangling, net<0 => OVER-REMOVE)\n",
+		 rmva, cl << PAGE_SHIFT, pfn, rmmm);
+	for (i = 0; i < PGCL_VK; i++) {
+		struct pgcl_ev2 *e = &vb->add[i];
+		bool mm_match, victim;
+
+		if (!e->ts || ((unsigned long)e->vaddr >> PAGE_SHIFT) != cl)
+			continue;
+		mm_match = (e->mm == rmmm);
+		victim = (e->pfn == pfn && mm_match);
+		found++;
+		if (victim) { net += e->delta; nadd++; }
+		pr_alert("  %s ADD ts=%llu cpu=%u %c d%+d va=%lx pfn=%lx mm=%lx%s -> mc=%d rc=%d\n",
+			 victim ? ">>>" : "   ",
+			 e->ts, e->cpu, e->tag ? e->tag : '?', e->delta,
+			 (unsigned long)e->vaddr, e->pfn, e->mm,
+			 mm_match ? "(same-mm)" : "(other-mm)", e->mc, e->rc);
+	}
+	for (i = 0; i < PGCL_VK; i++) {
+		struct pgcl_ev2 *e = &vb->rem[i];
+		bool mm_match, victim;
+
+		if (!e->ts || ((unsigned long)e->vaddr >> PAGE_SHIFT) != cl)
+			continue;
+		mm_match = (e->mm == rmmm);
+		victim = (e->pfn == pfn && mm_match);
+		found++;
+		if (victim) { net += e->delta; nrem++; }
+		pr_alert("  %s REM ts=%llu cpu=%u %c d%+d va=%lx pfn=%lx mm=%lx%s -> mc=%d rc=%d\n",
+			 victim ? ">>>" : "   ",
+			 e->ts, e->cpu, e->tag ? e->tag : '?', e->delta,
+			 (unsigned long)e->vaddr, e->pfn, e->mm,
+			 mm_match ? "(same-mm)" : "(other-mm)", e->mc, e->rc);
+	}
+	if (!found) {
+		pr_alert("  (no vaddr-bearing event retained for this cluster)\n");
+		return;
+	}
+	pr_alert("PGCL#143va: VERDICT victim pfn=%lx mm=%lx cluster va=%lx: net=%ld (adds=%d rems=%d) => %s\n",
+		 pfn, rmmm, cl << PAGE_SHIFT, net, nadd, nrem,
+		 net > 0 ? "UNDER-REMOVE: a >>> ADD above has no matching teardown = the dangling PTE; its tag names the leaking install path" :
+		 net < 0 ? "OVER-REMOVE: a >>> REM above has no matching install" :
+		 "BALANCED for retained events (leak predates window or is in another mm/cluster)");
+}
+
+/*
+ * #143 DEEP large-folio-ONLY ring.  Partition by folio class: only large folios
+ * write here, so the order-0 anon hog flood (the bulk of rmap volume) never
+ * evicts these events.  Keyed by folio HEAD pfn so a victim folio's full
+ * per-sub-PTE add/remove history is retained; each event records THIS kernel
+ * page's _mapcount (pmc) so an ADD with no matching REMOVE (pmc never returns
+ * to -1) stands out at the disc catch.
+ */
+struct pgcl_lev {
+	u64 ts;
+	unsigned long head_pfn;
+	unsigned long sub_pfn;
+	unsigned long mm;
+	long vaddr;
+	int delta;
+	int lmc;	/* _large_mapcount after */
+	int nm;		/* _nr_pages_mapped after */
+	int pmc;	/* this kernel page's _mapcount after */
+	u8 tag;
+	u8 cpu;
+};
+#define PGCL_NLB 2048
+#define PGCL_LK  128
+struct pgcl_lbucket {
+	atomic_t head;
+	struct pgcl_lev e[PGCL_LK];
+};
+static struct pgcl_lbucket pgcl_lbuckets[PGCL_NLB];
+
+void pgcl_lev_log(const struct folio *folio, struct page *page, int delta,
+		  long vaddr, int tag, unsigned long mm)
+{
+	unsigned long hpfn = folio_pfn(folio);
+	struct pgcl_lbucket *b = &pgcl_lbuckets[hpfn & (PGCL_NLB - 1)];
+	struct pgcl_lev *e;
+
+	preempt_disable();
+	e = &b->e[(unsigned int)(atomic_inc_return(&b->head) - 1) % PGCL_LK];
+	e->ts = local_clock();
+	e->head_pfn = hpfn;
+	e->sub_pfn = page_to_pfn(page);
+	e->mm = mm;
+	e->vaddr = vaddr;
+	e->delta = delta;
+	e->lmc = atomic_read(&folio->_large_mapcount);
+	e->nm = atomic_read(&folio->_nr_pages_mapped);
+	e->pmc = atomic_read(&page->_mapcount);
+	e->tag = (u8)tag;
+	e->cpu = raw_smp_processor_id();
+	preempt_enable();
+}
+
+void pgcl_lev_dump(unsigned long head_pfn)
+{
+	struct pgcl_lbucket *b = &pgcl_lbuckets[head_pfn & (PGCL_NLB - 1)];
+	static int idx[PGCL_LK];		/* static: no big stack frame */
+	static DEFINE_SPINLOCK(dlock);
+	static atomic_t cap = ATOMIC_INIT(0);
+	unsigned long flags;
+	int n = 0, i, j;
+
+	if (atomic_inc_return(&cap) > 8)	/* don't flood: first 8 dumps/boot */
+		return;
+	spin_lock_irqsave(&dlock, flags);
+	for (i = 0; i < PGCL_LK; i++)
+		if (b->e[i].ts && b->e[i].head_pfn == head_pfn)
+			idx[n++] = i;
+	for (i = 0; i < n; i++)		/* selection-sort indices by ts */
+		for (j = i + 1; j < n; j++)
+			if (b->e[idx[j]].ts < b->e[idx[i]].ts) {
+				int t = idx[i]; idx[i] = idx[j]; idx[j] = t;
+			}
+	pr_alert("PGCL#143lev: large-folio timeline head_pfn=%lx (%d events; per sub-pfn, an ADD with no matching REMOVE leaves pmc>=0)\n",
+		 head_pfn, n);
+	for (i = 0; i < n; i++) {
+		struct pgcl_lev *e = &b->e[idx[i]];
+
+		pr_alert("  ts=%llu cpu=%u %c sub=%lx d%+d -> pmc=%d lmc=%d nm=%d va=%lx mm=%lx\n",
+			 e->ts, e->cpu, e->tag ? e->tag : '?', e->sub_pfn,
+			 e->delta, e->pmc, e->lmc, e->nm,
+			 (unsigned long)e->vaddr, e->mm);
+	}
+	spin_unlock_irqrestore(&dlock, flags);
+}
