+/* === #143 per-CPU per-pfn timeline (huge, bootmem-scale) ================
+ * Nadia's design: PER-CPU buffers => no cross-CPU cacheline bounce (the shared
+ * ring locked the box up); HUGE (vzalloc'd, ~1% RAM, her mem_map precedent) =>
+ * retention deep enough to keep a folio's *install*, not just its removes;
+ * per-pfn hashed WITHIN each CPU => the catch dump is a cheap per-CPU bucket
+ * lookup, not a scan of millions.  Records rmap adds/removes AND set_ptes
+ * installs ('P'): a 'P' with no matching 'a'/'A'/'e'/'c'/'n' add for a pfn is
+ * the UNDER-ADD (a PTE installed without its rmap count), named by its caller.
+ */
+#define PGCL143_NB 8192		/* per-CPU pfn-hash buckets */
+#define PGCL143_NK 64		/* events retained per pfn bucket */
+struct pgcl143_ev {
+	unsigned long pfn, ip;
+	u64 ts;
+	short delta, mc, rc;
+	unsigned char cpu;
+	char tag;
+};
+struct pgcl143_bkt { unsigned int head; struct pgcl143_ev ev[PGCL143_NK]; };
+static DEFINE_PER_CPU(struct pgcl143_bkt *, pgcl143_rings);
+
+static int __init pgcl143_ring_init(void)
+{
+	unsigned int c;
+
+	for_each_possible_cpu(c)
+		per_cpu(pgcl143_rings, c) =
+			vzalloc_node(sizeof(struct pgcl143_bkt) * PGCL143_NB,
+				     cpu_to_node(c));
+	return 0;
+}
+early_initcall(pgcl143_ring_init);
+
+/* All callers run under the PTL (preempt off) => this_cpu is stable. */
+void pgcl143_rec(unsigned long pfn, int delta, int mc, int rc, char tag,
+		 unsigned long ip)
+{
+	struct pgcl143_bkt *rings = this_cpu_read(pgcl143_rings);
+	struct pgcl143_bkt *b;
+	struct pgcl143_ev *e;
+
+	if (!rings)
+		return;
+	b = &rings[pfn & (PGCL143_NB - 1)];
+	e = &b->ev[b->head++ & (PGCL143_NK - 1)];
+	e->pfn = pfn; e->ip = ip; e->ts = local_clock();
+	e->delta = delta; e->mc = mc;
+	e->rc = rc > 32767 ? 32767 : rc;
+	e->cpu = raw_smp_processor_id(); e->tag = tag;
+}
+static void pgcl143_dump(unsigned long pfn)
+{
+	unsigned int c, i, idx = pfn & (PGCL143_NB - 1);
+
+	pr_err("PGCL143tl: pfn=%lx per-CPU timeline (merge by ts; P=install, a/A/e/c/n=rmap-add, r/R=remove)\n",
+	       pfn);
+	for_each_possible_cpu(c) {
+		struct pgcl143_bkt *rings = per_cpu(pgcl143_rings, c);
+		struct pgcl143_bkt *b;
+
+		if (!rings)
+			continue;
+		b = &rings[idx];
+		for (i = 0; i < PGCL143_NK; i++) {
+			struct pgcl143_ev *e = &b->ev[(b->head + i) & (PGCL143_NK - 1)];
+
+			if (e->pfn != pfn || !e->tag)
+				continue;
+			pr_err("   cpu%u ts=%llu %c d%+d -> mc=%d rc=%d %pS\n",
+			       e->cpu, e->ts, e->tag, e->delta, e->mc, e->rc,
+			       (void *)e->ip);
+		}
+	}
+}
