#!/bin/sh
# PGCL #143 bisection: disable fault-around (fault_around_pages<=1) BEFORE systemd
# starts, so all file faults go through set_pte_range, not filemap_set_ptes_cluster.
mount -t debugfs none /sys/kernel/debug 2>/dev/null
echo 65536 > /sys/kernel/debug/fault_around_bytes 2>/dev/null
echo "FA-OFF: fault_around_bytes=$(cat /sys/kernel/debug/fault_around_bytes 2>/dev/null)" > /dev/console 2>/dev/null
exec /sbin/init "$@"
