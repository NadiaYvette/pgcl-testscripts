#!/bin/sh
# PGCL Boot Test Init Script
# Mount filesystems without redirects (no /dev/null yet)
mount -t proc proc /proc
mount -t sysfs sys /sys
mount -t devtmpfs devtmpfs /dev || true
mount -t tmpfs tmpfs /tmp || true
mkdir -p /dev/shm
mount -t tmpfs tmpfs /dev/shm || true

# Ensure critical device nodes exist even if devtmpfs failed
[ -c /dev/null ] || mknod /dev/null c 1 3 2>/dev/null
[ -c /dev/zero ] || mknod /dev/zero c 1 5 2>/dev/null
[ -c /dev/urandom ] || mknod /dev/urandom c 1 9 2>/dev/null

# Redirect stdio to kernel message buffer and console
# On some QEMU targets (e.g. LoongArch virt), /dev/console and /dev/ttyS0
# don't produce visible output — only kmsg reaches the serial port
if [ -c /dev/kmsg ]; then
    exec 1>/dev/kmsg 2>&1
elif [ -c /dev/console ]; then
    exec 0</dev/console 1>/dev/console 2>&1
fi

export PATH="/bin:/sbin:/usr/bin:/usr/sbin"
export HOME=/root
export TMPDIR=/tmp

# Set up user database for LTP tests that need "nobody" user
mkdir -p /etc /root /var/tmp
echo "root:x:0:0:root:/root:/bin/sh" > /etc/passwd
echo "nobody:x:65534:65534:nobody:/:/bin/false" >> /etc/passwd
echo "root:x:0:" > /etc/group
echo "nobody:x:65534:" >> /etc/group

# Get page size for mmapstress invocations
PGSZ=4096
if command -v getconf >/dev/null 2>&1; then
    _pgsz=$(getconf PAGESIZE 2>/dev/null)
    [ -n "$_pgsz" ] && PGSZ="$_pgsz"
fi

echo "========================================"
echo " PGCL Boot Test - $(uname -m)"
echo "========================================"
echo "Kernel: $(uname -r)"
echo "Page size (AT_PAGESZ): $PGSZ"
if [ -f /proc/meminfo ]; then
    read line < /proc/meminfo; echo "$line"
fi
TOTAL_PASS=0; TOTAL_FAIL=0
echo ""
if [ -x /bin/pgcl-test ]; then
    echo "--- Running PGCL basic tests ---"
    /bin/pgcl-test
    [ $? -eq 0 ] && TOTAL_PASS=$((TOTAL_PASS+1)) || TOTAL_FAIL=$((TOTAL_FAIL+1))
    echo ""
fi
if [ -x /bin/pgcl-stress ]; then
    echo "--- Running PGCL stress tests ---"
    /bin/pgcl-stress
    [ $? -eq 0 ] && TOTAL_PASS=$((TOTAL_PASS+1)) || TOTAL_FAIL=$((TOTAL_FAIL+1))
    echo ""
fi
if [ -d /bin/mm-selftests ]; then
    echo "--- Running kernel mm selftests ---"
    for t in /bin/mm-selftests/*; do
        [ -x "$t" ] || continue
        name="${t##*/}"
        # Skip tests known-problematic in minimal initramfs
        case "$name" in
            droppable) echo "  $name: SKIP (OOM test)"; continue ;;
            compaction_test) echo "  $name: SKIP (takes too long under QEMU)"; continue ;;
            mseal_test) echo "  $name: SKIP (requires root)"; continue ;;
            *.o) continue ;;  # skip .o helper files
        esac
        echo "  [$name]"
        timeout 120 "$t" >/tmp/selftest-out 2>&1
        ret=$?
        if [ $ret -eq 124 ] || [ $ret -eq 137 ] || [ $ret -eq 143 ]; then echo "  $name: SKIP (timeout)"; continue; fi
        if [ $ret -eq 0 ]; then echo "  $name: PASS"; TOTAL_PASS=$((TOTAL_PASS+1))
        elif [ $ret -eq 4 ]; then echo "  $name: SKIP"
        else echo "  $name: FAIL (exit=$ret)"; TOTAL_FAIL=$((TOTAL_FAIL+1)); fi
        echo ""
    done
fi
if [ -d /bin/ltp ]; then
    echo "--- Running LTP mm tests ---"
    LTP_PASS=0; LTP_FAIL=0; LTP_SKIP=0
    : > /tmp/ltp-results.txt
    for t in /bin/ltp/*; do
        [ -x "$t" ] || continue
        name="${t##*/}"
        # Skip tests that genuinely cannot run in minimal initramfs.
        # Write SKIP reasons to file only — keep console pressure low
        # so slow UARTs (m68k goldfish, sparc64 sun4u) don't drop the
        # subtotals/FAIL LIST lines we actually care about.
        skip_reason=""
        case "$name" in
            fork_procs) skip_reason="resource-intensive" ;;
            fork14) skip_reason="overcommit stress, floods console" ;;
            mmapstress08) skip_reason="heavy swap stress" ;;
            mmapstress01|mmapstress04|mmapstress07|mmapstress09) skip_reason="file mmap stress, hangs HPPA QEMU" ;;
            mmapstress10) skip_reason="needs writable file mapping" ;;
            mmap-corruption01) skip_reason="needs disk file" ;;
            madvise11) skip_reason="needs CONFIG_MEMORY_FAILURE + hwpoison_inject" ;;
            vma05_vdso) skip_reason="needs gdb for core dump analysis" ;;
            sbrk01|sbrk02) skip_reason="musl sbrk stub" ;;
            mmapstress02|mmapstress03|mmapstress05|mmapstress06) skip_reason="uses sbrk, musl stub" ;;
            mmap1) skip_reason="needs zcat for /proc/config.gz" ;;
            vma01) skip_reason="old LTP API, resource-intensive" ;;
            vma02|vma04) skip_reason="needs libnuma" ;;
            shmat1) skip_reason="needs SysV IPC setup" ;;
            madvise06|madvise07) skip_reason="needs hwpoison" ;;
            mmap16) skip_reason="needs block device" ;;
            mmap22) skip_reason="needs memory cgroups" ;;
            msync04) skip_reason="needs block device for loop" ;;
            madvise01) skip_reason="hwpoison SIGBUS test" ;;
            munmap04) skip_reason="65K regions, cleanup timeout" ;;
        esac
        if [ -n "$skip_reason" ]; then
            echo "  $name: SKIP ($skip_reason)" >> /tmp/ltp-results.txt
            LTP_SKIP=$((LTP_SKIP+1))
            continue
        fi
        # Tests that need specific CLI arguments or longer timeouts
        case "$name" in
            mmapstress06)
                timeout 30 "$t" 5 >/tmp/ltp-out 2>&1 ;;
            mmapstress07)
                timeout 30 "$t" /tmp/mmapstress07.tmp >/tmp/ltp-out 2>&1 ;;
            mmapstress09)
                timeout 90 "$t" -p 4 -t 1 -s 65536 >/tmp/ltp-out 2>&1 ;;
            mmapstress10)
                timeout 60 "$t" -p 4 -t 1 -f "$PGSZ" >/tmp/ltp-out 2>&1 ;;
            fork13)
                LTP_RUNTIME_MUL=0.01 timeout 60 "$t" >/tmp/ltp-out 2>&1 ;;
            mmap1)
                LTP_RUNTIME_MUL=0.05 timeout 60 "$t" >/tmp/ltp-out 2>&1 ;;
            mmap3)
                LTP_RUNTIME_MUL=0.1 timeout 60 "$t" >/tmp/ltp-out 2>&1 ;;
            fork07|fork09)
                # Fork-heavy tests can hit the LTP 30s internal alarm on
                # slow QEMU targets under PGCL=6 (256KB pages amplify
                # fork/fd-table setup costs).  Raise both the LTP
                # framework alarm (LTP_TIMEOUT_MUL) and the outer
                # wall-clock timeout so the test runs to completion.
                LTP_TIMEOUT_MUL=4 timeout 180 "$t" >/tmp/ltp-out 2>&1 ;;
            *)
                timeout 30 "$t" >/tmp/ltp-out 2>&1 ;;
        esac
        ret=$?
        if [ $ret -eq 0 ]; then
            echo "  $name: PASS" >> /tmp/ltp-results.txt; LTP_PASS=$((LTP_PASS+1))
        elif [ $ret -eq 4 ] || [ $ret -eq 32 ]; then
            echo "  $name: SKIP" >> /tmp/ltp-results.txt; LTP_SKIP=$((LTP_SKIP+1))
        elif [ $ret -eq 137 ] || [ $ret -eq 124 ] || [ $ret -eq 143 ]; then
            echo "  $name: SKIP (timeout)" >> /tmp/ltp-results.txt; LTP_SKIP=$((LTP_SKIP+1))
        else
            echo "  $name: FAIL (exit=$ret)"
            # Dump last 5 lines of test output IMMEDIATELY to console
            # so they survive even if the trailing detail loop is
            # truncated by autotest poweroff / UART back-pressure.
            tail -5 /tmp/ltp-out 2>/dev/null | while IFS= read -r ln; do
                echo "    $ln"
            done
            echo "  $name: FAIL (exit=$ret)" >> /tmp/ltp-results.txt
            echo "$name" >> /tmp/ltp-fail-names.txt
            echo "    --- $name output ---" >> /tmp/ltp-results.txt
            tail -8 /tmp/ltp-out >> /tmp/ltp-results.txt 2>/dev/null
            echo "    --- end $name output ---" >> /tmp/ltp-results.txt
            LTP_FAIL=$((LTP_FAIL+1))
        fi
    done
    echo "  LTP subtotals: $LTP_PASS passed, $LTP_FAIL failed, $LTP_SKIP skipped"
    if [ -s /tmp/ltp-fail-names.txt ]; then
        # Compact one-liner that survives console truncation.
        # Some embedded shells (sparc64 sash etc.) trip on $(tr ... <file);
        # fall back to a plain read-loop.
        FAIL_LIST=""
        while read fn; do
            FAIL_LIST="$FAIL_LIST $fn"
        done < /tmp/ltp-fail-names.txt
        echo "  LTP FAIL LIST:$FAIL_LIST"
    fi
    echo "--- LTP Details ---"
    # Print one line at a time with brief delay to avoid console rate limiting
    while IFS= read -r line; do
        echo "$line"
    done < /tmp/ltp-results.txt 2>/dev/null
    TOTAL_PASS=$((TOTAL_PASS+LTP_PASS)); TOTAL_FAIL=$((TOTAL_FAIL+LTP_FAIL))
    echo ""
fi
echo "========================================"
echo " Test Summary: $TOTAL_PASS passed, $TOTAL_FAIL failed"
echo "========================================"
if command -v dmesg >/dev/null 2>&1; then
    if dmesg 2>/dev/null | grep -viE "command line:|panic=" | grep -qE "BUG:|BUG |Oops|panic[^=]|Bad page state|WARNING:"; then
        echo "WARNING: kernel log contains errors!"
        dmesg | grep -viE "command line:|panic=" | grep -E "BUG:|BUG |Oops|panic[^=]|Bad page state|WARNING:" | head -10
    fi
fi
echo ""
AUTOTEST=0
if [ -f /proc/cmdline ]; then
    read cmdline < /proc/cmdline
    case "$cmdline" in *autotest=1*) AUTOTEST=1 ;; esac
fi
if [ "$AUTOTEST" = "1" ]; then
    # Flush console output before poweroff
    sync 2>/dev/null || true
    sleep 1
    echo "Autotest mode: powering off."
    # Try multiple poweroff methods
    if [ -f /proc/sysrq-trigger ]; then
        echo o > /proc/sysrq-trigger 2>/dev/null
    fi
    reboot -f 2>/dev/null || poweroff -f 2>/dev/null || true
    sleep 5 2>/dev/null || { i=0; while [ $i -lt 99999999 ]; do i=$((i+1)); done; }
fi
if [ -x /bin/sh ]; then
    echo "Type 'poweroff -f' to exit QEMU."
    exec /bin/sh
else
    echo "No shell available. Powering off."
    reboot -f 2>/dev/null || echo o > /proc/sysrq-trigger 2>/dev/null || true
fi
